+{-# LANGUAGE Trustworthy #-}
+{-# LANGUAGE NoImplicitPrelude #-}
+
+-----------------------------------------------------------------------------
+-- |
+-- Module      :  GHC.Internal.Control.Monad.CommutativeDo
+--
+-- Internal support for opt-in commutative do-notation.  User-facing code
+-- should import "Control.Monad.CommutativeDo" from @base@ instead.
+
+module GHC.Internal.Control.Monad.CommutativeDo
+  ( CommutativeMonad
+  , __commutative_do__
+  , (>>=)
+  , (>>)
+  , return
+  , pure
+  , fmap
+  , (<*>)
+  , join
+  , fail
+  ) where
+
+import qualified GHC.Internal.Base as B
+import qualified GHC.Internal.Control.Monad.Fail as Fail
+
+-- | Marker class for monads whose independent effects may be reordered by
+-- the experimental commutative-do ApplicativeDo extension.
+--
+-- This class is a programmer assertion: GHC does not prove commutativity.
+class B.Monad m => CommutativeMonad m
+
+-- | Marker looked up by the renamer for @QualifiedDo@ blocks.  A block written
+-- as @M.do@ is eligible for commutative reordering only when @M@ exports this
+-- binding and the corresponding compiler flag is enabled.
+__commutative_do__ :: ()
+__commutative_do__ = ()
+
+infixl 1 >>=, >>
+infixl 4 <*>
+
+(>>=) :: CommutativeMonad m => m a -> (a -> m b) -> m b
+(>>=) = (B.>>=)
+
+(>>) :: CommutativeMonad m => m a -> m b -> m b
+(>>) = (B.>>)
+
+return :: CommutativeMonad m => a -> m a
+return = B.pure
+
+pure :: CommutativeMonad m => a -> m a
+pure = B.pure
+
+fmap :: CommutativeMonad m => (a -> b) -> m a -> m b
+fmap = B.fmap
+
+(<*>) :: CommutativeMonad m => m (a -> b) -> m a -> m b
+(<*>) = (B.<*>)
+
+join :: CommutativeMonad m => m (m a) -> m a
+join mma = mma >>= B.id
+
+fail :: (CommutativeMonad m, Fail.MonadFail m) => B.String -> m a
+fail = Fail.fail
