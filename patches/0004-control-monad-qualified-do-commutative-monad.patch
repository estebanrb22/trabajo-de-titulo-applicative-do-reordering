+{-# LANGUAGE Safe #-}
+
+-- |
+-- Module      :  Control.Monad.CommutativeDo
+--
+-- Opt-in operations for commutative do-notation under @QualifiedDo@.
+-- Import this module qualified and write @CD.do@ to mark a do-block as
+-- eligible for the experimental commutative ApplicativeDo reordering.
+
+module Control.Monad.CommutativeDo
+  ( CommutativeMonad
+  , __commutative_do__
+  , (>>=)
+  , (>>)
+  , return
+  , pure
+  , fmap
+  , (<*>)
+  , join
+  , fail
+  ) where
+
+import GHC.Internal.Control.Monad.CommutativeDo
