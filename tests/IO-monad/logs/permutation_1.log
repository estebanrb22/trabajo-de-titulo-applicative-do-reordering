-- Reordered do-notation
CD.do
  y <- putStrLn "B" >> pure 2
  x <- putStrLn "A" >> pure 1
  CD.return (x + y)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [2, 1]
  statements  =  [y_a1T4 <- putStrLn "B" >> pure 2,
                  x_a1T3 <- putStrLn "A" >> pure 1]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (y_a1T4 <- putStrLn "B" >> pure 2,
                     {>>, pure, putStrLn}))
       (StmtTreeOne (x_a1T3 <- putStrLn "A" >> pure 1,
                     {>>, pure, putStrLn})))
  tree-cost = 1

-- Execution plan
y | x
