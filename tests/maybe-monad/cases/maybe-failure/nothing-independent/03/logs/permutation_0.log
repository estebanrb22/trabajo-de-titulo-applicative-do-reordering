-- Reordered do-notation
CD.do
  x1 <- Just 1
  x2 <- Nothing
  x3 <- Just 10
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3]
  statements  =  [x1_a1T3 <- Just 1, x2_a1T4 <- Nothing,
                  x3_a1T5 <- Just 10]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x1_a1T3 <- Just 1, {Just}))
       (StmtTreeOne (x2_a1T4 <- Nothing, {Nothing}))
       (StmtTreeOne (x3_a1T5 <- Just 10, {Just})))
  tree-cost = 1

-- Execution plan
x1 | x2 | x3
