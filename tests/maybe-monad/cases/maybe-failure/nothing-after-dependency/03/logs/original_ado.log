-- do-notation
do
  x1 <- Just 0
  x2 <- if x1 > 0 then Just 1 else Nothing
  x3 <- Just 100
  return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeBind
        (StmtTreeOne (x1_a1S3 <- Just 0, {Just}))
        (StmtTreeOne (x2_a1S4 <- if x1_a1S3 > 0 then Just 1 else Nothing,
                      {Nothing, Just, x1_a1S3, >})))
     (StmtTreeOne (x3_a1S5 <- Just 100, {Just})))
  tree-cost = 2

-- Execution plan
(x1 ; x2) | x3
