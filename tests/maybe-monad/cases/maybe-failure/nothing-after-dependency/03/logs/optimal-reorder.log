-- Reordered do-notation
CD.do
  x1 <- Just 0
  x2 <- if x1 > 0 then Just 1 else Nothing
  x3 <- Just 100
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3]
  statements  =  [x1_a1T2 <- Just 0,
                  x2_a1T3 <- if x1_a1T2 > 0 then Just 1 else Nothing,
                  x3_a1T4 <- Just 100]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeBind
          (StmtTreeOne (x1_a1T2 <- Just 0, {Just}))
          (StmtTreeOne (x2_a1T3 <- if x1_a1T2 > 0 then Just 1 else Nothing,
                        {Nothing, Just, x1_a1T2, >})))
       (StmtTreeOne (x3_a1T4 <- Just 100, {Just})))
  tree-cost = 2

-- Execution plan
(x1 ; x2) | x3
