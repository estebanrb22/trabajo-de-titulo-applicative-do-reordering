-- Reordered do-notation
CD.do
  x3 <- Just 100
  x1 <- Just 0
  x2 <- if x1 > 0 then Just 1 else Nothing
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  2
  index-order =  [3, 1, 2]
  statements  =  [x3_a1T5 <- Just 100, x1_a1T3 <- Just 0,
                  x2_a1T4 <- if x1_a1T3 > 0 then Just 1 else Nothing]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x3_a1T5 <- Just 100, {Just}))
       (StmtTreeBind
          (StmtTreeOne (x1_a1T3 <- Just 0, {Just}))
          (StmtTreeOne (x2_a1T4 <- if x1_a1T3 > 0 then Just 1 else Nothing,
                        {Nothing, Just, x1_a1T3, >}))))
  tree-cost = 2

-- Execution plan
x3 | (x1 ; x2)
