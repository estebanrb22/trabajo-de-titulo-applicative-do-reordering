-- do-notation
do
  [x1, x2] <- Just [1]
  x3 <- Just (x1 + 10)
  x4 <- Just 100
  return (x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeBind
        (StmtTreeOne ([x1_a1S3, x2_a1S4] <- Just [1], {Just}))
        (StmtTreeOne (x3_a1S5 <- Just (x1_a1S3 + 10), {Just, x1_a1S3, +})))
     (StmtTreeOne (x4_a1S6 <- Just 100, {Just})))
  tree-cost = 2

-- Execution plan
([x1, x2] ; x3) | x4
