-- Reordered do-notation
CD.do
  x4 <- Just 100
  (x1, Just x2) <- Just (1, Nothing)
  x3 <- Just (x1 + x2)
  CD.return (x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  2
  index-order =  [3, 1, 2]
  statements  =  [x4_a1T6 <- Just 100,
                  (x1_a1T3, Just x2_a1T4) <- Just (1, Nothing),
                  x3_a1T5 <- Just (x1_a1T3 + x2_a1T4)]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x4_a1T6 <- Just 100, {Just}))
       (StmtTreeBind
          (StmtTreeOne ((x1_a1T3, Just x2_a1T4) <- Just (1, Nothing),
                        {Nothing, Just}))
          (StmtTreeOne (x3_a1T5 <- Just (x1_a1T3 + x2_a1T4),
                        {Just, x1_a1T3, x2_a1T4, +}))))
  tree-cost = 2

-- Execution plan
x4 | ((x1, Just x2) ; x3)
