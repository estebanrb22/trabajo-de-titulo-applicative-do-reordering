-- Reordered do-notation
CD.do
  (x1, Just x2) <- Just (1, Nothing)
  x3 <- Just (x1 + x2)
  x4 <- Just 100
  CD.return (x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3]
  statements  =  [(x1_a1T3, Just x2_a1T4) <- Just (1, Nothing),
                  x3_a1T5 <- Just (x1_a1T3 + x2_a1T4), x4_a1T6 <- Just 100]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeBind
          (StmtTreeOne ((x1_a1T3, Just x2_a1T4) <- Just (1, Nothing),
                        {Nothing, Just}))
          (StmtTreeOne (x3_a1T5 <- Just (x1_a1T3 + x2_a1T4),
                        {Just, x1_a1T3, x2_a1T4, +})))
       (StmtTreeOne (x4_a1T6 <- Just 100, {Just})))
  tree-cost = 2

-- Execution plan
((x1, Just x2) ; x3) | x4
