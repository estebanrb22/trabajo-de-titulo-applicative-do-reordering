-- Original program
CD.do
  (x1, Just x2) <- Just (1, Nothing)
  x3 <- Just (x1 + x2)
  x4 <- Just 100
  CD.return (x1, x2, x3, x4)

-- Internal representation with free variables by statement
ppsfa
  [((x1_a1T2, Just x2_a1T3) <- Just (1, Nothing), {Nothing, Just}),
   (x3_a1T4 <- Just (x1_a1T2 + x2_a1T3), {Just, x1_a1T2, x2_a1T3, +}),
   (x4_a1T5 <- Just 100, {Just}),
   (CD.return (x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5), {x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5, CD.return})]

-- Precedence graph adjacency list
1 -> {2}
2 -> {}
3 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {2}
