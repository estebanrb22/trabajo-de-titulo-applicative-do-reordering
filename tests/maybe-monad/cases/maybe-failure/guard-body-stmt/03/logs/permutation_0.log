-- Reordered do-notation
CD.do
  x1 <- Just 0
  if x1 > 0 then Just () else Nothing
  x2 <- Just 10
  CD.return (x1, x2)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3]
  statements  =  [x1_a1T3 <- Just 0,
                  if x1_a1T3 > 0 then Just () else Nothing, x2_a1T4 <- Just 10]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeBind
          (StmtTreeOne (x1_a1T3 <- Just 0, {Just}))
          (StmtTreeOne (if x1_a1T3 > 0 then Just () else Nothing,
                        {Nothing, Just, (), x1_a1T3, >})))
       (StmtTreeOne (x2_a1T4 <- Just 10, {Just})))
  tree-cost = 2

-- Execution plan
(x1 ; stmt2) | x2
