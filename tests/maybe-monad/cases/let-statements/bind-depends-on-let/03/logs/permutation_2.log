-- Reordered do-notation
CD.do
  x3 <- Just 100
  let x1 = 10
  x2 <- Just (x1 + 1)
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  2
  index-order =  [3, 1, 2]
  statements  =  [x3_a1T5 <- Just 100, let x1_a1T3 = 10,
                  x2_a1T4 <- Just (x1_a1T3 + 1)]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x3_a1T5 <- Just 100, {Just}))
       (StmtTreeBind
          (StmtTreeOne (let x1_a1T3 = 10, {}))
          (StmtTreeOne (x2_a1T4 <- Just (x1_a1T3 + 1), {Just, x1_a1T3, +}))))
  tree-cost = 2

-- Execution plan
x3 | (x1 ; x2)
