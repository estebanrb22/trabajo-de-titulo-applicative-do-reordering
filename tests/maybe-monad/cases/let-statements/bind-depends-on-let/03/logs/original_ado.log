-- do-notation
do
  let x1 = 10
  x2 <- Just (x1 + 1)
  x3 <- Just 100
  return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeBind
        (StmtTreeOne (let x1_a1S3 = 10, {}))
        (StmtTreeOne (x2_a1S4 <- Just (x1_a1S3 + 1), {Just, x1_a1S3, +})))
     (StmtTreeOne (x3_a1S5 <- Just 100, {Just})))
  tree-cost = 2

-- Execution plan
(x1 ; x2) | x3
