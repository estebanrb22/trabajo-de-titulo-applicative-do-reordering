-- Reordered do-notation
CD.do
  let x1 = 10
  x2 <- Just (x1 + 1)
  x3 <- Just 100
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3]
  statements  =  [let x1_a1T2 = 10, x2_a1T3 <- Just (x1_a1T2 + 1),
                  x3_a1T4 <- Just 100]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeBind
          (StmtTreeOne (let x1_a1T2 = 10, {}))
          (StmtTreeOne (x2_a1T3 <- Just (x1_a1T2 + 1), {Just, x1_a1T2, +})))
       (StmtTreeOne (x3_a1T4 <- Just 100, {Just})))
  tree-cost = 2

-- Execution plan
(x1 ; x2) | x3
