-- Reordered do-notation
CD.do
  x2 <- Just 10
  x3 <- Just 100
  let x1 = 1
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  3
  index-order =  [2, 3, 1]
  statements  =  [x2_a1T3 <- Just 10, x3_a1T4 <- Just 100,
                  let x1_a1T2 = 1]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x2_a1T3 <- Just 10, {Just}))
       (StmtTreeOne (x3_a1T4 <- Just 100, {Just}))
       (StmtTreeOne (let x1_a1T2 = 1, {})))
  tree-cost = 1

-- Execution plan
x2 | x3 | x1
