-- Reordered do-notation
CD.do
  x3 <- Just 100
  let x1 = 1
  x2 <- Just 10
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  4
  index-order =  [3, 1, 2]
  statements  =  [x3_a1T5 <- Just 100, let x1_a1T3 = 1,
                  x2_a1T4 <- Just 10]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x3_a1T5 <- Just 100, {Just}))
       (StmtTreeBind
          (StmtTreeOne (let x1_a1T3 = 1, {}))
          (StmtTreeOne (x2_a1T4 <- Just 10, {Just}))))
  tree-cost = 2

-- Execution plan
x3 | (x1 ; x2)
