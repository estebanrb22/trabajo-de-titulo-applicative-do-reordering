-- do-notation
do
  let x1 = 1
  x2 <- Just 10
  x3 <- Just 100
  return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeBind
        (StmtTreeOne (let x1_a1S3 = 1, {}))
        (StmtTreeOne (x2_a1S4 <- Just 10, {Just})))
     (StmtTreeOne (x3_a1S5 <- Just 100, {Just})))
  tree-cost = 2

-- Execution plan
(x1 ; x2) | x3
