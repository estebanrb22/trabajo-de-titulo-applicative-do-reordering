-- Reordered do-notation
CD.do
  x2 <- Just 10
  let x1 = 1
  x3 <- Just 100
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  2
  index-order =  [2, 1, 3]
  statements  =  [x2_a1T4 <- Just 10, let x1_a1T3 = 1,
                  x3_a1T5 <- Just 100]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x2_a1T4 <- Just 10, {Just}))
       (StmtTreeBind
          (StmtTreeOne (let x1_a1T3 = 1, {}))
          (StmtTreeOne (x3_a1T5 <- Just 100, {Just}))))
  tree-cost = 2

-- Execution plan
x2 | (x1 ; x3)
