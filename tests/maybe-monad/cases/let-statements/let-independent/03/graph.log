-- Original program
CD.do
  let x1 = 1
  x2 <- Just 10
  x3 <- Just 100
  CD.return (x1, x2, x3)

-- Internal representation with free variables by statement
ppsfa
  [(let x1_a1T2 = 1, {}),
   (x2_a1T3 <- Just 10, {Just}),
   (x3_a1T4 <- Just 100, {Just}),
   (CD.return (x1_a1T2, x2_a1T3, x3_a1T4), {x1_a1T2, x2_a1T3, x3_a1T4, CD.return})]

