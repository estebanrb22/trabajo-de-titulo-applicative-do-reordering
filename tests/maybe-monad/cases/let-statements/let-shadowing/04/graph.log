-- Original program
CD.do
  x <- Just 1
  oldX <- Just x
  let x = 100
  y <- Just (x + oldX)
  CD.return (oldX, x, y)

-- Internal representation with free variables by statement
ppsfa
  [(x_a1T2 <- Just 1, {Just}),
   (oldX_a1T3 <- Just x_a1T2, {Just, x_a1T2}),
   (let x_a1T4 = 100, {}),
   (y_a1T5 <- Just (x_a1T4 + oldX_a1T3), {Just, oldX_a1T3, x_a1T4, +}),
   (CD.return (oldX_a1T3, x_a1T4, y_a1T5), {oldX_a1T3, x_a1T4, y_a1T5, CD.return})]

