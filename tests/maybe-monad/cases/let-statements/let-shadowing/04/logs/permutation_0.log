-- Reordered do-notation
CD.do
  x <- Just 1
  oldX <- Just x
  let x = 100
  y <- Just (x + oldX)
  CD.return (oldX, x, y)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3, 4]
  statements  =  [x_a1T3 <- Just 1, oldX_a1T4 <- Just x_a1T3,
                  let x_a1T5 = 100, y_a1T6 <- Just (x_a1T5 + oldX_a1T4)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (x_a1T3 <- Just 1, {Just}))
       (StmtTreeBind
          (StmtTreeOne (oldX_a1T4 <- Just x_a1T3, {Just, x_a1T3}))
          (StmtTreeBind
             (StmtTreeOne (let x_a1T5 = 100, {}))
             (StmtTreeOne (y_a1T6 <- Just (x_a1T5 + oldX_a1T4),
                           {Just, oldX_a1T4, x_a1T5, +})))))
  tree-cost = 4

-- Execution plan
x ; (oldX ; (x ; y))
