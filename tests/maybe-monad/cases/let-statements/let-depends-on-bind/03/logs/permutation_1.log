-- Reordered do-notation
CD.do
  x1 <- Just 10
  x3 <- Just 100
  let x2 = x1 + 1
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [1, 3, 2]
  statements  =  [x1_a1T3 <- Just 10, x3_a1T5 <- Just 100,
                  let x2_a1T4 = x1_a1T3 + 1]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x1_a1T3 <- Just 10, {Just}))
          (StmtTreeOne (x3_a1T5 <- Just 100, {Just})))
       (StmtTreeOne (let x2_a1T4 = x1_a1T3 + 1, {x1_a1T3, +})))
  tree-cost = 2

-- Execution plan
(x1 | x3) ; x2
