-- do-notation
do
  x1 <- Just 10
  let x2 = x1 + 1
  x3 <- Just 100
  return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeBind
        (StmtTreeOne (x1_a1S3 <- Just 10, {Just}))
        (StmtTreeOne (let x2_a1S4 = x1_a1S3 + 1, {x1_a1S3, +})))
     (StmtTreeOne (x3_a1S5 <- Just 100, {Just})))
  tree-cost = 2

-- Execution plan
(x1 ; x2) | x3
