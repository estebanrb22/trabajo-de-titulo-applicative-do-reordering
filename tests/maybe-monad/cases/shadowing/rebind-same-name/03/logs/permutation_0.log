-- Reordered do-notation
CD.do
  x <- Just 1
  x <- Just 10
  y <- Just 100
  CD.return (x, y)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3]
  statements  =  [x_a1T3 <- Just 1, x_a1T4 <- Just 10,
                  y_a1T5 <- Just 100]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x_a1T3 <- Just 1, {Just}))
       (StmtTreeOne (x_a1T4 <- Just 10, {Just}))
       (StmtTreeOne (y_a1T5 <- Just 100, {Just})))
  tree-cost = 1

-- Execution plan
x | x | y
