-- Reordered do-notation
CD.do
  x <- Just 10
  x <- Just 1
  y <- Just (x + 100)
  CD.return (x, y)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [2, 1, 3]
  statements  =  [x_a1T4 <- Just 10, x_a1T3 <- Just 1,
                  y_a1T5 <- Just (x_a1T4 + 100)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x_a1T4 <- Just 10, {Just}))
          (StmtTreeOne (x_a1T3 <- Just 1, {Just})))
       (StmtTreeOne (y_a1T5 <- Just (x_a1T4 + 100), {Just, x_a1T4, +})))
  tree-cost = 2

-- Execution plan
(x | x) ; y
