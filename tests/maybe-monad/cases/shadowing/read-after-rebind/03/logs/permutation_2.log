-- Reordered do-notation
CD.do
  x <- Just 10
  y <- Just (x + 100)
  x <- Just 1
  CD.return (x, y)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  2
  index-order =  [2, 3, 1]
  statements  =  [x_a1T4 <- Just 10, y_a1T5 <- Just (x_a1T4 + 100),
                  x_a1T3 <- Just 1]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeBind
          (StmtTreeOne (x_a1T4 <- Just 10, {Just}))
          (StmtTreeOne (y_a1T5 <- Just (x_a1T4 + 100), {Just, x_a1T4, +})))
       (StmtTreeOne (x_a1T3 <- Just 1, {Just})))
  tree-cost = 2

-- Execution plan
(x ; y) | x
