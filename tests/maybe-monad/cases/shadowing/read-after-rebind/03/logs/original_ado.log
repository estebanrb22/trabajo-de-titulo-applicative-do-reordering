-- do-notation
do
  x <- Just 1
  x <- Just 10
  y <- Just (x + 100)
  return (x, y)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeOne (x_a1S3 <- Just 1, {Just}))
     (StmtTreeBind
        (StmtTreeOne (x_a1S4 <- Just 10, {Just}))
        (StmtTreeOne (y_a1S5 <- Just (x_a1S4 + 100), {Just, x_a1S4, +}))))
  tree-cost = 2

-- Execution plan
x | (x ; y)
