-- Original program
CD.do
  x <- Just 1
  y <- Just (x + 10)
  x <- Just 100
  CD.return (y, x)

-- Internal representation with free variables by statement
ppsfa
  [(x_a1T2 <- Just 1, {Just}),
   (y_a1T3 <- Just (x_a1T2 + 10), {Just, x_a1T2, +}),
   (x_a1T4 <- Just 100, {Just}),
   (CD.return (y_a1T3, x_a1T4), {y_a1T3, x_a1T4, CD.return})]

