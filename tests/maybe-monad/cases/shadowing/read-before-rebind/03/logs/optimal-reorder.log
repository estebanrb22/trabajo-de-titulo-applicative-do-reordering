-- Reordered do-notation
CD.do
  x <- Just 1
  y <- Just (x + 10)
  x <- Just 100
  CD.return (y, x)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3]
  statements  =  [x_a1T2 <- Just 1, y_a1T3 <- Just (x_a1T2 + 10),
                  x_a1T4 <- Just 100]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeBind
          (StmtTreeOne (x_a1T2 <- Just 1, {Just}))
          (StmtTreeOne (y_a1T3 <- Just (x_a1T2 + 10), {Just, x_a1T2, +})))
       (StmtTreeOne (x_a1T4 <- Just 100, {Just})))
  tree-cost = 2

-- Execution plan
(x ; y) | x
