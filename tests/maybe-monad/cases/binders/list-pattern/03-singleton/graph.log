-- Original program
CD.do
  [x1] <- Just [10]
  x2 <- Just 20
  x3 <- Just (x1 + x2)
  CD.return (x1, x2, x3)

-- Internal representation with free variables by statement
ppsfa
  [([x1_a1T2] <- Just [10], {Just}),
   (x2_a1T3 <- Just 20, {Just}),
   (x3_a1T4 <- Just (x1_a1T2 + x2_a1T3), {Just, x1_a1T2, x2_a1T3, +}),
   (CD.return (x1_a1T2, x2_a1T3, x3_a1T4), {x1_a1T2, x2_a1T3, x3_a1T4, CD.return})]

-- Precedence graph adjacency list
1 -> {3}
2 -> {3}
3 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {3}
x2: 2 -> {3}
