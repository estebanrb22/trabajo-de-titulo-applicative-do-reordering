-- do-notation
do
  [x1] <- Just [10]
  x2 <- Just 20
  x3 <- Just (x1 + x2)
  return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeOne ([x1_a1S3] <- Just [10], {Just}))
     (StmtTreeBind
        (StmtTreeOne (x2_a1S4 <- Just 20, {Just}))
        (StmtTreeOne (x3_a1S5 <- Just (x1_a1S3 + x2_a1S4),
                      {Just, x1_a1S3, x2_a1S4, +}))))
  tree-cost = 3

-- Execution plan
[x1] ; (x2 ; x3)
