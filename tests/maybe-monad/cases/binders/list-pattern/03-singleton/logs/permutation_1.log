-- Reordered do-notation
CD.do
  x2 <- Just 20
  [x1] <- Just [10]
  x3 <- Just (x1 + x2)
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [2, 1, 3]
  statements  =  [x2_a1T4 <- Just 20, [x1_a1T3] <- Just [10],
                  x3_a1T5 <- Just (x1_a1T3 + x2_a1T4)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (x2_a1T4 <- Just 20, {Just}))
       (StmtTreeBind
          (StmtTreeOne ([x1_a1T3] <- Just [10], {Just}))
          (StmtTreeOne (x3_a1T5 <- Just (x1_a1T3 + x2_a1T4),
                        {Just, x1_a1T3, x2_a1T4, +}))))
  tree-cost = 3

-- Execution plan
x2 ; ([x1] ; x3)
