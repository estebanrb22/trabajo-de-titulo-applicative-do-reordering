-- Reordered do-notation
CD.do
  (x1:x2:xs) <- Just [1, 10, 100, 1000]
  x4 <- Just (sum xs)
  x3 <- Just (x1 + x2)
  x5 <- Just (x3 + x4)
  CD.return (x1, x2, xs, x3, x4, x5)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [1, 3, 2, 4]
  statements  =  [(x1_a1T3 : x2_a1T4 : xs_a1T5) <- Just
                                                     [1, 10, 100, 1000],
                  x4_a1T7 <- Just (sum xs_a1T5), x3_a1T6 <- Just (x1_a1T3 + x2_a1T4),
                  x5_a1T8 <- Just (x3_a1T6 + x4_a1T7)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne ((x1_a1T3 : x2_a1T4 : xs_a1T5) <- Just
                                                        [1, 10, 100, 1000],
                     {Just}))
       (StmtTreeBind
          (StmtTreeApplicative
             (StmtTreeOne (x4_a1T7 <- Just (sum xs_a1T5), {Just, xs_a1T5, sum}))
             (StmtTreeOne (x3_a1T6 <- Just (x1_a1T3 + x2_a1T4),
                           {Just, x1_a1T3, x2_a1T4, +})))
          (StmtTreeOne (x5_a1T8 <- Just (x3_a1T6 + x4_a1T7),
                        {Just, x3_a1T6, x4_a1T7, +}))))
  tree-cost = 3

-- Execution plan
(x1:x2:xs) ; ((x4 | x3) ; x5)
