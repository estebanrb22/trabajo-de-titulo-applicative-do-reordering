-- Reordered do-notation
CD.do
  (x1:x2:xs) <- Just [1, 10, 100, 1000]
  x3 <- Just (x1 + x2)
  x4 <- Just (sum xs)
  x5 <- Just (x3 + x4)
  CD.return (x1, x2, xs, x3, x4, x5)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3, 4]
  statements  =  [(x1_a1T2 : x2_a1T3 : xs_a1T4) <- Just
                                                     [1, 10, 100, 1000],
                  x3_a1T5 <- Just (x1_a1T2 + x2_a1T3), x4_a1T6 <- Just (sum xs_a1T4),
                  x5_a1T7 <- Just (x3_a1T5 + x4_a1T6)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne ((x1_a1T2 : x2_a1T3 : xs_a1T4) <- Just
                                                        [1, 10, 100, 1000],
                     {Just}))
       (StmtTreeBind
          (StmtTreeApplicative
             (StmtTreeOne (x3_a1T5 <- Just (x1_a1T2 + x2_a1T3),
                           {Just, x1_a1T2, x2_a1T3, +}))
             (StmtTreeOne (x4_a1T6 <- Just (sum xs_a1T4),
                           {Just, xs_a1T4, sum})))
          (StmtTreeOne (x5_a1T7 <- Just (x3_a1T5 + x4_a1T6),
                        {Just, x3_a1T5, x4_a1T6, +}))))
  tree-cost = 3

-- Execution plan
(x1:x2:xs) ; ((x3 | x4) ; x5)
