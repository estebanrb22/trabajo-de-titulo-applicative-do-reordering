-- Original program
CD.do
  (x1:x2:xs) <- Just [1, 10, 100, 1000]
  x3 <- Just (x1 + x2)
  x4 <- Just (sum xs)
  x5 <- Just (x3 + x4)
  CD.return (x1, x2, xs, x3, x4, x5)

-- Internal representation with free variables by statement
ppsfa
  [((x1_a1T2 : x2_a1T3 : xs_a1T4) <- Just [1, 10, 100, 1000], {Just}),
   (x3_a1T5 <- Just (x1_a1T2 + x2_a1T3), {Just, x1_a1T2, x2_a1T3, +}),
   (x4_a1T6 <- Just (sum xs_a1T4), {Just, xs_a1T4, sum}),
   (x5_a1T7 <- Just (x3_a1T5 + x4_a1T6), {Just, x3_a1T5, x4_a1T6, +}),
   (CD.return (x1_a1T2, x2_a1T3, xs_a1T4, x3_a1T5, x4_a1T6, x5_a1T7), {x1_a1T2, x2_a1T3, xs_a1T4, x3_a1T5, x4_a1T6, x5_a1T7, CD.return})]

-- Precedence graph adjacency list
1 -> {2, 3}
2 -> {4}
3 -> {4}
4 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {2}
x2: 1 -> {2}
xs: 1 -> {3}
x3: 2 -> {4}
x4: 3 -> {4}
