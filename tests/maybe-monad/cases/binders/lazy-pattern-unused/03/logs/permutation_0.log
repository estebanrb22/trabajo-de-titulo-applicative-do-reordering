-- Reordered do-notation
CD.do
  ~[x1] <- Just []
  x2 <- Just 10
  x3 <- Just (x2 + 1)
  CD.return (x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3]
  statements  =  [~[x1_a1T3] <- Just [], x2_a1T4 <- Just 10,
                  x3_a1T5 <- Just (x2_a1T4 + 1)]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (~[x1_a1T3] <- Just [], {Just, []}))
       (StmtTreeBind
          (StmtTreeOne (x2_a1T4 <- Just 10, {Just}))
          (StmtTreeOne (x3_a1T5 <- Just (x2_a1T4 + 1), {Just, x2_a1T4, +}))))
  tree-cost = 2

-- Execution plan
~[x1] | (x2 ; x3)
