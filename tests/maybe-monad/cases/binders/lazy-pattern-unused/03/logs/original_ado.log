-- do-notation
do
  ~[x1] <- Just []
  x2 <- Just 10
  x3 <- Just (x2 + 1)
  return (x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeOne (~[x1_a1S3] <- Just [], {Just, []}))
     (StmtTreeBind
        (StmtTreeOne (x2_a1S4 <- Just 10, {Just}))
        (StmtTreeOne (x3_a1S5 <- Just (x2_a1S4 + 1), {Just, x2_a1S4, +}))))
  tree-cost = 2

-- Execution plan
~[x1] | (x2 ; x3)
