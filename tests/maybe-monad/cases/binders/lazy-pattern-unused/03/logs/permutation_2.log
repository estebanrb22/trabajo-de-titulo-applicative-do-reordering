-- Reordered do-notation
CD.do
  x2 <- Just 10
  x3 <- Just (x2 + 1)
  ~[x1] <- Just []
  CD.return (x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  2
  index-order =  [2, 3, 1]
  statements  =  [x2_a1T4 <- Just 10, x3_a1T5 <- Just (x2_a1T4 + 1),
                  ~[x1_a1T3] <- Just []]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeBind
          (StmtTreeOne (x2_a1T4 <- Just 10, {Just}))
          (StmtTreeOne (x3_a1T5 <- Just (x2_a1T4 + 1), {Just, x2_a1T4, +})))
       (StmtTreeOne (~[x1_a1T3] <- Just [], {Just, []})))
  tree-cost = 2

-- Execution plan
(x2 ; x3) | ~[x1]
