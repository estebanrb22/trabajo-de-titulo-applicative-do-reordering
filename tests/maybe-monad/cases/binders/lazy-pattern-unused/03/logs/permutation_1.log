-- Reordered do-notation
CD.do
  x2 <- Just 10
  ~[x1] <- Just []
  x3 <- Just (x2 + 1)
  CD.return (x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [2, 1, 3]
  statements  =  [x2_a1T4 <- Just 10, ~[x1_a1T3] <- Just [],
                  x3_a1T5 <- Just (x2_a1T4 + 1)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x2_a1T4 <- Just 10, {Just}))
          (StmtTreeOne (~[x1_a1T3] <- Just [], {Just, []})))
       (StmtTreeOne (x3_a1T5 <- Just (x2_a1T4 + 1), {Just, x2_a1T4, +})))
  tree-cost = 2

-- Execution plan
(x2 | ~[x1]) ; x3
