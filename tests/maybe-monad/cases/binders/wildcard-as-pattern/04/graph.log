-- Original program
CD.do
  pair@(x1, _) <- Just (1, 10)
  x2 <- Just (fst pair + 20)
  x3 <- Just (x1 + 30)
  x4 <- Just (x2 + x3)
  CD.return (pair, x1, x2, x3, x4)

-- Internal representation with free variables by statement
ppsfa
  [(pair_a1T2@(x1_a1T3, _) <- Just (1, 10), {Just}),
   (x2_a1T4 <- Just (fst pair_a1T2 + 20), {Just, pair_a1T2, fst, +}),
   (x3_a1T5 <- Just (x1_a1T3 + 30), {Just, x1_a1T3, +}),
   (x4_a1T6 <- Just (x2_a1T4 + x3_a1T5), {Just, x2_a1T4, x3_a1T5, +}),
   (CD.return (pair_a1T2, x1_a1T3, x2_a1T4, x3_a1T5, x4_a1T6), {pair_a1T2, x1_a1T3, x2_a1T4, x3_a1T5, x4_a1T6, CD.return})]

-- Precedence graph adjacency list
1 -> {2, 3}
2 -> {4}
3 -> {4}
4 -> {}

-- Precedence graph RAW dependencies grouped by binder
pair: 1 -> {2}
x1: 1 -> {3}
x2: 2 -> {4}
x3: 3 -> {4}
