-- Reordered do-notation
CD.do
  pair@(x1, _) <- Just (1, 10)
  x2 <- Just (fst pair + 20)
  x3 <- Just (x1 + 30)
  x4 <- Just (x2 + x3)
  CD.return (pair, x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3, 4]
  statements  =  [pair_a1T3@(x1_a1T4, _) <- Just (1, 10),
                  x2_a1T5 <- Just (fst pair_a1T3 + 20),
                  x3_a1T6 <- Just (x1_a1T4 + 30),
                  x4_a1T7 <- Just (x2_a1T5 + x3_a1T6)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (pair_a1T3@(x1_a1T4, _) <- Just (1, 10), {Just}))
       (StmtTreeBind
          (StmtTreeApplicative
             (StmtTreeOne (x2_a1T5 <- Just (fst pair_a1T3 + 20),
                           {Just, pair_a1T3, fst, +}))
             (StmtTreeOne (x3_a1T6 <- Just (x1_a1T4 + 30), {Just, x1_a1T4, +})))
          (StmtTreeOne (x4_a1T7 <- Just (x2_a1T5 + x3_a1T6),
                        {Just, x2_a1T5, x3_a1T6, +}))))
  tree-cost = 3

-- Execution plan
pair@(x1, _) ; ((x2 | x3) ; x4)
