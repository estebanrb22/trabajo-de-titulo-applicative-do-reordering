-- do-notation
do
  pair@(x1, _) <- Just (1, 10)
  x2 <- Just (fst pair + 20)
  x3 <- Just (x1 + 30)
  x4 <- Just (x2 + x3)
  return (pair, x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeOne (pair_a1S3@(x1_a1S4, _) <- Just (1, 10), {Just}))
     (StmtTreeBind
        (StmtTreeApplicative
           (StmtTreeOne (x2_a1S5 <- Just (fst pair_a1S3 + 20),
                         {Just, pair_a1S3, fst, +}))
           (StmtTreeOne (x3_a1S6 <- Just (x1_a1S4 + 30), {Just, x1_a1S4, +})))
        (StmtTreeOne (x4_a1S7 <- Just (x2_a1S5 + x3_a1S6),
                      {Just, x2_a1S5, x3_a1S6, +}))))
  tree-cost = 3

-- Execution plan
pair@(x1, _) ; ((x2 | x3) ; x4)
