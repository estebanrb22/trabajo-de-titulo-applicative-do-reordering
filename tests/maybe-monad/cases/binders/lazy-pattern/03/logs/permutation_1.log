-- Reordered do-notation
CD.do
  ~[x1, x2] <- Just [1, 10]
  x4 <- Just (x2 + 1)
  x3 <- Just (x1 + 1)
  CD.return (x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [1, 3, 2]
  statements  =  [~[x1_a1T3, x2_a1T4] <- Just [1, 10],
                  x4_a1T6 <- Just (x2_a1T4 + 1), x3_a1T5 <- Just (x1_a1T3 + 1)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (~[x1_a1T3, x2_a1T4] <- Just [1, 10], {Just}))
       (StmtTreeApplicative
          (StmtTreeOne (x4_a1T6 <- Just (x2_a1T4 + 1), {Just, x2_a1T4, +}))
          (StmtTreeOne (x3_a1T5 <- Just (x1_a1T3 + 1), {Just, x1_a1T3, +}))))
  tree-cost = 2

-- Execution plan
~[x1, x2] ; (x4 | x3)
