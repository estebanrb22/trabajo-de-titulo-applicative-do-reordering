-- Original program
CD.do
  (x1, x2, x3) <- Just (1, 10, 100)
  x4 <- Just (x1 + 1)
  x5 <- Just (x2 + 1)
  x6 <- Just (x3 + 1)
  x7 <- Just (x4 + x5 + x6)
  CD.return (x1, x2, x3, x4, x5, x6, x7)

-- Internal representation with free variables by statement
ppsfa
  [((x1_a1T2, x2_a1T3, x3_a1T4) <- Just (1, 10, 100), {Just}),
   (x4_a1T5 <- Just (x1_a1T2 + 1), {Just, x1_a1T2, +}),
   (x5_a1T6 <- Just (x2_a1T3 + 1), {Just, x2_a1T3, +}),
   (x6_a1T7 <- Just (x3_a1T4 + 1), {Just, x3_a1T4, +}),
   (x7_a1T8 <- Just (x4_a1T5 + x5_a1T6 + x6_a1T7), {Just, x4_a1T5, x5_a1T6, x6_a1T7, +}),
   (CD.return (x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5, x5_a1T6, x6_a1T7, x7_a1T8), {x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5, x5_a1T6, x6_a1T7, x7_a1T8, CD.return})]

-- Precedence graph adjacency list
1 -> {2, 3, 4}
2 -> {5}
3 -> {5}
4 -> {5}
5 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {2}
x2: 1 -> {3}
x3: 1 -> {4}
x4: 2 -> {5}
x5: 3 -> {5}
x6: 4 -> {5}
