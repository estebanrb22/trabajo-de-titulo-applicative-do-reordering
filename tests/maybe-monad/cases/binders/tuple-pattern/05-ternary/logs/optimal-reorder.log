-- Reordered do-notation
CD.do
  (x1, x2, x3) <- Just (1, 10, 100)
  x4 <- Just (x1 + 1)
  x5 <- Just (x2 + 1)
  x6 <- Just (x3 + 1)
  x7 <- Just (x4 + x5 + x6)
  CD.return (x1, x2, x3, x4, x5, x6, x7)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3, 4, 5]
  statements  =  [(x1_a1T2, x2_a1T3, x3_a1T4) <- Just (1, 10, 100),
                  x4_a1T5 <- Just (x1_a1T2 + 1), x5_a1T6 <- Just (x2_a1T3 + 1),
                  x6_a1T7 <- Just (x3_a1T4 + 1),
                  x7_a1T8 <- Just (x4_a1T5 + x5_a1T6 + x6_a1T7)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne ((x1_a1T2, x2_a1T3, x3_a1T4) <- Just (1, 10, 100),
                     {Just}))
       (StmtTreeBind
          (StmtTreeApplicative
             (StmtTreeOne (x4_a1T5 <- Just (x1_a1T2 + 1), {Just, x1_a1T2, +}))
             (StmtTreeOne (x5_a1T6 <- Just (x2_a1T3 + 1), {Just, x2_a1T3, +}))
             (StmtTreeOne (x6_a1T7 <- Just (x3_a1T4 + 1), {Just, x3_a1T4, +})))
          (StmtTreeOne (x7_a1T8 <- Just (x4_a1T5 + x5_a1T6 + x6_a1T7),
                        {Just, x4_a1T5, x5_a1T6, x6_a1T7, +}))))
  tree-cost = 3

-- Execution plan
(x1, x2, x3) ; ((x4 | x5 | x6) ; x7)
