-- do-notation
do
  (x1, x2, x3) <- Just (1, 10, 100)
  x4 <- Just (x1 + 1)
  x5 <- Just (x2 + 1)
  x6 <- Just (x3 + 1)
  x7 <- Just (x4 + x5 + x6)
  return (x1, x2, x3, x4, x5, x6, x7)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeOne ((x1_a1S3, x2_a1S4, x3_a1S5) <- Just (1, 10, 100),
                   {Just}))
     (StmtTreeBind
        (StmtTreeApplicative
           (StmtTreeOne (x4_a1S6 <- Just (x1_a1S3 + 1), {Just, x1_a1S3, +}))
           (StmtTreeOne (x5_a1S7 <- Just (x2_a1S4 + 1), {Just, x2_a1S4, +}))
           (StmtTreeOne (x6_a1S8 <- Just (x3_a1S5 + 1), {Just, x3_a1S5, +})))
        (StmtTreeOne (x7_a1S9 <- Just (x4_a1S6 + x5_a1S7 + x6_a1S8),
                      {Just, x4_a1S6, x5_a1S7, x6_a1S8, +}))))
  tree-cost = 3

-- Execution plan
(x1, x2, x3) ; ((x4 | x5 | x6) ; x7)
