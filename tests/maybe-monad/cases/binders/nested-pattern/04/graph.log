-- Original program
CD.do
  ((x1, x2), (x3, x4)) <- Just ((1, 10), (100, 1000))
  x5 <- Just (x1 + x3)
  x6 <- Just (x2 + x4)
  x7 <- Just (x5 + x6)
  CD.return (x1, x2, x3, x4, x5, x6, x7)

-- Internal representation with free variables by statement
ppsfa
  [(((x1_a1T2, x2_a1T3), (x3_a1T4, x4_a1T5)) <- Just ((1, 10), (100, 1000)), {Just}),
   (x5_a1T6 <- Just (x1_a1T2 + x3_a1T4), {Just, x1_a1T2, x3_a1T4, +}),
   (x6_a1T7 <- Just (x2_a1T3 + x4_a1T5), {Just, x2_a1T3, x4_a1T5, +}),
   (x7_a1T8 <- Just (x5_a1T6 + x6_a1T7), {Just, x5_a1T6, x6_a1T7, +}),
   (CD.return (x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5, x5_a1T6, x6_a1T7, x7_a1T8), {x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5, x5_a1T6, x6_a1T7, x7_a1T8, CD.return})]

-- Precedence graph adjacency list
1 -> {2, 3}
2 -> {4}
3 -> {4}
4 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {2}
x2: 1 -> {3}
x3: 1 -> {2}
x4: 1 -> {3}
x5: 2 -> {4}
x6: 3 -> {4}
