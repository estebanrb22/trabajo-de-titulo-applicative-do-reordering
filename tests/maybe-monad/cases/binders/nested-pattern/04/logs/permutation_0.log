-- Reordered do-notation
CD.do
  ((x1, x2), (x3, x4)) <- Just ((1, 10), (100, 1000))
  x5 <- Just (x1 + x3)
  x6 <- Just (x2 + x4)
  x7 <- Just (x5 + x6)
  CD.return (x1, x2, x3, x4, x5, x6, x7)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3, 4]
  statements  =  [((x1_a1T3, x2_a1T4), (x3_a1T5, x4_a1T6)) <- Just
                                                                ((1, 10), (100, 1000)),
                  x5_a1T7 <- Just (x1_a1T3 + x3_a1T5),
                  x6_a1T8 <- Just (x2_a1T4 + x4_a1T6),
                  x7_a1T9 <- Just (x5_a1T7 + x6_a1T8)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (((x1_a1T3, x2_a1T4), (x3_a1T5, x4_a1T6)) <- Just
                                                                   ((1, 10), (100, 1000)),
                     {Just}))
       (StmtTreeBind
          (StmtTreeApplicative
             (StmtTreeOne (x5_a1T7 <- Just (x1_a1T3 + x3_a1T5),
                           {Just, x1_a1T3, x3_a1T5, +}))
             (StmtTreeOne (x6_a1T8 <- Just (x2_a1T4 + x4_a1T6),
                           {Just, x2_a1T4, x4_a1T6, +})))
          (StmtTreeOne (x7_a1T9 <- Just (x5_a1T7 + x6_a1T8),
                        {Just, x5_a1T7, x6_a1T8, +}))))
  tree-cost = 3

-- Execution plan
((x1, x2), (x3, x4)) ; ((x5 | x6) ; x7)
