-- Original program
CD.do
  x1 <- Just 1
  Just (x1 + 10)
  x2 <- Just 100
  CD.return (x1, x2)

-- Internal representation with free variables by statement
ppsfa
  [(x1_a1T2 <- Just 1, {Just}),
   (Just (x1_a1T2 + 10), {Just, x1_a1T2, +}),
   (x2_a1T3 <- Just 100, {Just}),
   (CD.return (x1_a1T2, x2_a1T3), {x1_a1T2, x2_a1T3, CD.return})]

-- Precedence graph adjacency list
1 -> {2}
2 -> {}
3 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {2}
