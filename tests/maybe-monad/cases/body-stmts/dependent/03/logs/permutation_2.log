-- Reordered do-notation
CD.do
  x2 <- Just 100
  x1 <- Just 1
  Just (x1 + 10)
  CD.return (x1, x2)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  2
  index-order =  [3, 1, 2]
  statements  =  [x2_a1T4 <- Just 100, x1_a1T3 <- Just 1,
                  Just (x1_a1T3 + 10)]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x2_a1T4 <- Just 100, {Just}))
       (StmtTreeBind
          (StmtTreeOne (x1_a1T3 <- Just 1, {Just}))
          (StmtTreeOne (Just (x1_a1T3 + 10), {Just, x1_a1T3, +}))))
  tree-cost = 2

-- Execution plan
x2 | (x1 ; stmt2)
