-- Original program
CD.do
  x1 <- Just 1
  x2 <- Just (x1 + 10)
  x3 <- Just 100
  x4 <- Just (x3 + 20)
  x5 <- Just (x4 + 30)
  x6 <- Just (x2 + 40)
  CD.return (x1, x2, x3, x4, x5, x6)

-- Internal representation with free variables by statement
ppsfa
  [(x1_a1T2 <- Just 1, {Just}),
   (x2_a1T3 <- Just (x1_a1T2 + 10), {Just, x1_a1T2, +}),
   (x3_a1T4 <- Just 100, {Just}),
   (x4_a1T5 <- Just (x3_a1T4 + 20), {Just, x3_a1T4, +}),
   (x5_a1T6 <- Just (x4_a1T5 + 30), {Just, x4_a1T5, +}),
   (x6_a1T7 <- Just (x2_a1T3 + 40), {Just, x2_a1T3, +}),
   (CD.return (x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5, x5_a1T6, x6_a1T7), {x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5, x5_a1T6, x6_a1T7, CD.return})]

-- Precedence graph adjacency list
1 -> {2}
2 -> {6}
3 -> {4}
4 -> {5}
5 -> {}
6 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {2}
