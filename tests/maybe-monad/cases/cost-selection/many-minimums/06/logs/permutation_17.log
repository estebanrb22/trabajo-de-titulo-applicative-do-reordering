-- Reordered do-notation
CD.do
  x3 <- Just 100
  x4 <- Just (x3 + 20)
  x1 <- Just 1
  x2 <- Just (x1 + 10)
  x6 <- Just (x2 + 40)
  x5 <- Just (x4 + 30)
  CD.return (x1, x2, x3, x4, x5, x6)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  17
  index-order =  [3, 4, 1, 2, 6, 5]
  statements  =  [x3_a1T5 <- Just 100,
                  x4_a1T6 <- Just (x3_a1T5 + 20), x1_a1T3 <- Just 1,
                  x2_a1T4 <- Just (x1_a1T3 + 10), x6_a1T8 <- Just (x2_a1T4 + 40),
                  x5_a1T7 <- Just (x4_a1T6 + 30)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (x3_a1T5 <- Just 100, {Just}))
       (StmtTreeBind
          (StmtTreeApplicative
             (StmtTreeOne (x4_a1T6 <- Just (x3_a1T5 + 20), {Just, x3_a1T5, +}))
             (StmtTreeOne (x1_a1T3 <- Just 1, {Just})))
          (StmtTreeApplicative
             (StmtTreeBind
                (StmtTreeOne (x2_a1T4 <- Just (x1_a1T3 + 10), {Just, x1_a1T3, +}))
                (StmtTreeOne (x6_a1T8 <- Just (x2_a1T4 + 40), {Just, x2_a1T4, +})))
             (StmtTreeOne (x5_a1T7 <- Just (x4_a1T6 + 30),
                           {Just, x4_a1T6, +})))))
  tree-cost = 4

-- Execution plan
x3 ; ((x4 | x1) ; ((x2 ; x6) | x5))
