-- Reordered do-notation
CD.do
  x1 <- Just 1
  x2 <- Just (x1 + 10)
  x3 <- Just (x2 + 20)
  (x4, _) <- Just (40, 0)
  x5 <- Just (x3 + 30)
  CD.return (x1, x2, x3, x4, x5)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3, 4, 5]
  statements  =  [x1_a1T3 <- Just 1, x2_a1T4 <- Just (x1_a1T3 + 10),
                  x3_a1T5 <- Just (x2_a1T4 + 20), (x4_a1T6, _) <- Just (40, 0),
                  x5_a1T7 <- Just (x3_a1T5 + 30)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (x1_a1T3 <- Just 1, {Just}))
       (StmtTreeBind
          (StmtTreeOne (x2_a1T4 <- Just (x1_a1T3 + 10), {Just, x1_a1T3, +}))
          (StmtTreeBind
             (StmtTreeOne (x3_a1T5 <- Just (x2_a1T4 + 20), {Just, x2_a1T4, +}))
             (StmtTreeBind
                (StmtTreeOne ((x4_a1T6, _) <- Just (40, 0), {Just}))
                (StmtTreeOne (x5_a1T7 <- Just (x3_a1T5 + 30),
                              {Just, x3_a1T5, +}))))))
  tree-cost = 5

-- Execution plan
x1 ; (x2 ; (x3 ; ((x4, _) ; x5)))
