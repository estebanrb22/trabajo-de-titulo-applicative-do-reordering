-- Reordered do-notation
CD.do
  x1 <- Just 1
  x2 <- Just (x1 + 10)
  x3 <- Just (x2 + 20)
  x5 <- Just (x3 + 30)
  (x4, _) <- Just (40, 0)
  CD.return (x1, x2, x3, x4, x5)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  1
  index-order =  [1, 2, 3, 5, 4]
  statements  =  [x1_a1T2 <- Just 1, x2_a1T3 <- Just (x1_a1T2 + 10),
                  x3_a1T4 <- Just (x2_a1T3 + 20), x5_a1T6 <- Just (x3_a1T4 + 30),
                  (x4_a1T5, _) <- Just (40, 0)]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeBind
          (StmtTreeOne (x1_a1T2 <- Just 1, {Just}))
          (StmtTreeBind
             (StmtTreeOne (x2_a1T3 <- Just (x1_a1T2 + 10), {Just, x1_a1T2, +}))
             (StmtTreeBind
                (StmtTreeOne (x3_a1T4 <- Just (x2_a1T3 + 20), {Just, x2_a1T3, +}))
                (StmtTreeOne (x5_a1T6 <- Just (x3_a1T4 + 30),
                              {Just, x3_a1T4, +})))))
       (StmtTreeOne ((x4_a1T5, _) <- Just (40, 0), {Just})))
  tree-cost = 4

-- Execution plan
(x1 ; (x2 ; (x3 ; x5))) | (x4, _)
