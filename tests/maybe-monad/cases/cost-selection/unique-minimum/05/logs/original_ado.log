-- do-notation
do
  x1 <- Just 1
  x2 <- Just (x1 + 10)
  x3 <- Just (x2 + 20)
  (x4, _) <- Just (40, 0)
  x5 <- Just (x3 + 30)
  return (x1, x2, x3, x4, x5)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeOne (x1_a1S3 <- Just 1, {Just}))
     (StmtTreeBind
        (StmtTreeOne (x2_a1S4 <- Just (x1_a1S3 + 10), {Just, x1_a1S3, +}))
        (StmtTreeBind
           (StmtTreeOne (x3_a1S5 <- Just (x2_a1S4 + 20), {Just, x2_a1S4, +}))
           (StmtTreeBind
              (StmtTreeOne ((x4_a1S6, _) <- Just (40, 0), {Just}))
              (StmtTreeOne (x5_a1S7 <- Just (x3_a1S5 + 30),
                            {Just, x3_a1S5, +}))))))
  tree-cost = 5

-- Execution plan
x1 ; (x2 ; (x3 ; ((x4, _) ; x5)))
