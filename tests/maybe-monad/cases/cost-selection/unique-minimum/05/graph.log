-- Original program
CD.do
  x1 <- Just 1
  x2 <- Just (x1 + 10)
  x3 <- Just (x2 + 20)
  (x4, _) <- Just (40, 0)
  x5 <- Just (x3 + 30)
  CD.return (x1, x2, x3, x4, x5)

-- Internal representation with free variables by statement
ppsfa
  [(x1_a1T2 <- Just 1, {Just}),
   (x2_a1T3 <- Just (x1_a1T2 + 10), {Just, x1_a1T2, +}),
   (x3_a1T4 <- Just (x2_a1T3 + 20), {Just, x2_a1T3, +}),
   ((x4_a1T5, _) <- Just (40, 0), {Just}),
   (x5_a1T6 <- Just (x3_a1T4 + 30), {Just, x3_a1T4, +}),
   (CD.return (x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5, x5_a1T6), {x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5, x5_a1T6, CD.return})]

-- Precedence graph adjacency list
1 -> {2}
2 -> {3}
3 -> {5}
4 -> {}
5 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {2}
x2: 2 -> {3}
x3: 3 -> {5}
