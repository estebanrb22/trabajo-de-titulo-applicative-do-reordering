-- Reordered do-notation
CD.do
  x1 <- Just 1
  x3 <- Just 100
  x2 <- Just (x1 + 10)
  x4 <- Just (x1 + x3)
  CD.return (x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  1
  index-order =  [1, 3, 2, 4]
  statements  =  [x1_a1T2 <- Just 1, x3_a1T4 <- Just 100,
                  x2_a1T3 <- Just (x1_a1T2 + 10),
                  x4_a1T5 <- Just (x1_a1T2 + x3_a1T4)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x1_a1T2 <- Just 1, {Just}))
          (StmtTreeOne (x3_a1T4 <- Just 100, {Just})))
       (StmtTreeApplicative
          (StmtTreeOne (x2_a1T3 <- Just (x1_a1T2 + 10), {Just, x1_a1T2, +}))
          (StmtTreeOne (x4_a1T5 <- Just (x1_a1T2 + x3_a1T4),
                        {Just, x1_a1T2, x3_a1T4, +}))))
  tree-cost = 2

-- Execution plan
(x1 | x3) ; (x2 | x4)
