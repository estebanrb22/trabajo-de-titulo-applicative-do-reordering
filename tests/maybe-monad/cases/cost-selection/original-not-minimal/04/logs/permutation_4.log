-- Reordered do-notation
CD.do
  x3 <- Just 100
  x1 <- Just 1
  x4 <- Just (x1 + x3)
  x2 <- Just (x1 + 10)
  CD.return (x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  4
  index-order =  [3, 1, 4, 2]
  statements  =  [x3_a1T5 <- Just 100, x1_a1T3 <- Just 1,
                  x4_a1T6 <- Just (x1_a1T3 + x3_a1T5),
                  x2_a1T4 <- Just (x1_a1T3 + 10)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x3_a1T5 <- Just 100, {Just}))
          (StmtTreeOne (x1_a1T3 <- Just 1, {Just})))
       (StmtTreeApplicative
          (StmtTreeOne (x4_a1T6 <- Just (x1_a1T3 + x3_a1T5),
                        {Just, x1_a1T3, x3_a1T5, +}))
          (StmtTreeOne (x2_a1T4 <- Just (x1_a1T3 + 10),
                        {Just, x1_a1T3, +}))))
  tree-cost = 2

-- Execution plan
(x3 | x1) ; (x4 | x2)
