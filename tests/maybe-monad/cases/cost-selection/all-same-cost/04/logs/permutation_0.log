-- Reordered do-notation
CD.do
  x1 <- Just 1
  x2 <- Just (x1 + 10)
  x3 <- Just (x1 + 20)
  x4 <- Just (x1 + 30)
  CD.return (x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3, 4]
  statements  =  [x1_a1T3 <- Just 1, x2_a1T4 <- Just (x1_a1T3 + 10),
                  x3_a1T5 <- Just (x1_a1T3 + 20), x4_a1T6 <- Just (x1_a1T3 + 30)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (x1_a1T3 <- Just 1, {Just}))
       (StmtTreeApplicative
          (StmtTreeOne (x2_a1T4 <- Just (x1_a1T3 + 10), {Just, x1_a1T3, +}))
          (StmtTreeOne (x3_a1T5 <- Just (x1_a1T3 + 20), {Just, x1_a1T3, +}))
          (StmtTreeOne (x4_a1T6 <- Just (x1_a1T3 + 30),
                        {Just, x1_a1T3, +}))))
  tree-cost = 2

-- Execution plan
x1 ; (x2 | x3 | x4)
