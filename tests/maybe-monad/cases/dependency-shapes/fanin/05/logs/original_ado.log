-- do-notation
do
  x1 <- Just 1
  x2 <- Just 10
  x3 <- Just 100
  x4 <- Just 1000
  x5 <- Just (x1 + x2 + x3 + x4)
  return (x1, x2, x3, x4, x5)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeApplicative
        (StmtTreeOne (x1_a1S3 <- Just 1, {Just}))
        (StmtTreeOne (x2_a1S4 <- Just 10, {Just}))
        (StmtTreeOne (x3_a1S5 <- Just 100, {Just}))
        (StmtTreeOne (x4_a1S6 <- Just 1000, {Just})))
     (StmtTreeOne (x5_a1S7 <- Just
                                (x1_a1S3 + x2_a1S4 + x3_a1S5 + x4_a1S6),
                   {Just, x1_a1S3, x2_a1S4, x3_a1S5, x4_a1S6, +})))
  tree-cost = 2

-- Execution plan
(x1 | x2 | x3 | x4) ; x5
