-- Reordered do-notation
CD.do
  x4 <- Just 1000
  x1 <- Just 1
  x2 <- Just 10
  x3 <- Just 100
  x5 <- Just (x1 + x2 + x3 + x4)
  CD.return (x1, x2, x3, x4, x5)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  18
  index-order =  [4, 1, 2, 3, 5]
  statements  =  [x4_a1T6 <- Just 1000, x1_a1T3 <- Just 1,
                  x2_a1T4 <- Just 10, x3_a1T5 <- Just 100,
                  x5_a1T7 <- Just (x1_a1T3 + x2_a1T4 + x3_a1T5 + x4_a1T6)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x4_a1T6 <- Just 1000, {Just}))
          (StmtTreeOne (x1_a1T3 <- Just 1, {Just}))
          (StmtTreeOne (x2_a1T4 <- Just 10, {Just}))
          (StmtTreeOne (x3_a1T5 <- Just 100, {Just})))
       (StmtTreeOne (x5_a1T7 <- Just
                                  (x1_a1T3 + x2_a1T4 + x3_a1T5 + x4_a1T6),
                     {Just, x1_a1T3, x2_a1T4, x3_a1T5, x4_a1T6, +})))
  tree-cost = 2

-- Execution plan
(x4 | x1 | x2 | x3) ; x5
