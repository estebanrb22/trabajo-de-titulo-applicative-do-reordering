-- Original program
CD.do
  x1 <- Just 1
  x2 <- Just 10
  x3 <- Just 100
  x4 <- Just 1000
  x5 <- Just (x1 + x2 + x3 + x4)
  CD.return (x1, x2, x3, x4, x5)

-- Internal representation with free variables by statement
ppsfa
  [(x1_a1T2 <- Just 1, {Just}),
   (x2_a1T3 <- Just 10, {Just}),
   (x3_a1T4 <- Just 100, {Just}),
   (x4_a1T5 <- Just 1000, {Just}),
   (x5_a1T6 <- Just (x1_a1T2 + x2_a1T3 + x3_a1T4 + x4_a1T5), {Just, x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5, +}),
   (CD.return (x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5, x5_a1T6), {x1_a1T2, x2_a1T3, x3_a1T4, x4_a1T5, x5_a1T6, CD.return})]

-- Precedence graph adjacency list
1 -> {5}
2 -> {5}
3 -> {5}
4 -> {5}
5 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {5}
x2: 2 -> {5}
x3: 3 -> {5}
x4: 4 -> {5}
