-- do-notation
do
  a1 <- Just 1
  b1 <- Just 10
  a2 <- Just (a1 + 1)
  b2 <- Just (b1 + 1)
  return (a1, a2, b1, b2)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeApplicative
        (StmtTreeOne (a1_a1S3 <- Just 1, {Just}))
        (StmtTreeOne (b1_a1S4 <- Just 10, {Just})))
     (StmtTreeApplicative
        (StmtTreeOne (a2_a1S5 <- Just (a1_a1S3 + 1), {Just, a1_a1S3, +}))
        (StmtTreeOne (b2_a1S6 <- Just (b1_a1S4 + 1), {Just, b1_a1S4, +}))))
  tree-cost = 2

-- Execution plan
(a1 | b1) ; (a2 | b2)
