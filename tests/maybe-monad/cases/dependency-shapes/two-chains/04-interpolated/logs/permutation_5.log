-- Reordered do-notation
CD.do
  b1 <- Just 10
  b2 <- Just (b1 + 1)
  a1 <- Just 1
  a2 <- Just (a1 + 1)
  CD.return (a1, a2, b1, b2)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  5
  index-order =  [2, 4, 1, 3]
  statements  =  [b1_a1T4 <- Just 10, b2_a1T6 <- Just (b1_a1T4 + 1),
                  a1_a1T3 <- Just 1, a2_a1T5 <- Just (a1_a1T3 + 1)]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeBind
          (StmtTreeOne (b1_a1T4 <- Just 10, {Just}))
          (StmtTreeOne (b2_a1T6 <- Just (b1_a1T4 + 1), {Just, b1_a1T4, +})))
       (StmtTreeBind
          (StmtTreeOne (a1_a1T3 <- Just 1, {Just}))
          (StmtTreeOne (a2_a1T5 <- Just (a1_a1T3 + 1), {Just, a1_a1T3, +}))))
  tree-cost = 2

-- Execution plan
(b1 ; b2) | (a1 ; a2)
