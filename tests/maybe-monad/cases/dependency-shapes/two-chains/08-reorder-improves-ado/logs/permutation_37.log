                (StmtTreeOne (a3_a1T5 <- Just (a2_a1T4 + 1), {Just, a2_a1T4, +}))
                (StmtTreeOne (b2_a1T7 <- Just (b1_a1T6 + 1), {Just, b1_a1T6, +})))
             (StmtTreeApplicative
                (StmtTreeOne (a4_a1T9 <- Just (a3_a1T5 + 1), {Just, a3_a1T5, +}))
                (StmtTreeBind
