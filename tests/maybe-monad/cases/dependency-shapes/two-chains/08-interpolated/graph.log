-- Original program
CD.do
  a1 <- Just 1
  b1 <- Just 10
  a2 <- Just (a1 + 1)
  b2 <- Just (b1 + 1)
  a3 <- Just (a2 + 1)
  b3 <- Just (b2 + 1)
  a4 <- Just (a3 + 1)
  b4 <- Just (b3 + 1)
  CD.return (a1, a2, a3, a4, b1, b2, b3, b4)

-- Internal representation with free variables by statement
ppsfa
  [(a1_a1T2 <- Just 1, {Just}),
   (b1_a1T3 <- Just 10, {Just}),
   (a2_a1T4 <- Just (a1_a1T2 + 1), {Just, a1_a1T2, +}),
   (b2_a1T5 <- Just (b1_a1T3 + 1), {Just, b1_a1T3, +}),
   (a3_a1T6 <- Just (a2_a1T4 + 1), {Just, a2_a1T4, +}),
   (b3_a1T7 <- Just (b2_a1T5 + 1), {Just, b2_a1T5, +}),
   (a4_a1T8 <- Just (a3_a1T6 + 1), {Just, a3_a1T6, +}),
   (b4_a1T9 <- Just (b3_a1T7 + 1), {Just, b3_a1T7, +}),
   (CD.return (a1_a1T2, a2_a1T4, a3_a1T6, a4_a1T8, b1_a1T3, b2_a1T5, b3_a1T7, b4_a1T9), {a1_a1T2, b1_a1T3, a2_a1T4, b2_a1T5, a3_a1T6, b3_a1T7, a4_a1T8, b4_a1T9, CD.return})]

