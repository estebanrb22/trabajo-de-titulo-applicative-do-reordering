-- Reordered do-notation
CD.do
  a1 <- Just 1
  b1 <- Just 10
  a2 <- Just (a1 + 1)
  b2 <- Just (b1 + 1)
  a3 <- Just (a2 + 1)
  b3 <- Just (b2 + 1)
  a4 <- Just (a3 + 1)
  b4 <- Just (b3 + 1)
  CD.return (a1, a2, a3, a4, b1, b2, b3, b4)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3, 4, 5, 6, 7, 8]
  statements  =  [a1_a1T3 <- Just 1, b1_a1T4 <- Just 10,
                  a2_a1T5 <- Just (a1_a1T3 + 1), b2_a1T6 <- Just (b1_a1T4 + 1),
                  a3_a1T7 <- Just (a2_a1T5 + 1), b3_a1T8 <- Just (b2_a1T6 + 1),
                  a4_a1T9 <- Just (a3_a1T7 + 1), b4_a1Ta <- Just (b3_a1T8 + 1)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (a1_a1T3 <- Just 1, {Just}))
          (StmtTreeOne (b1_a1T4 <- Just 10, {Just})))
       (StmtTreeBind
          (StmtTreeApplicative
             (StmtTreeOne (a2_a1T5 <- Just (a1_a1T3 + 1), {Just, a1_a1T3, +}))
             (StmtTreeOne (b2_a1T6 <- Just (b1_a1T4 + 1), {Just, b1_a1T4, +})))
          (StmtTreeBind
             (StmtTreeApplicative
                (StmtTreeOne (a3_a1T7 <- Just (a2_a1T5 + 1), {Just, a2_a1T5, +}))
                (StmtTreeOne (b3_a1T8 <- Just (b2_a1T6 + 1), {Just, b2_a1T6, +})))
             (StmtTreeApplicative
                (StmtTreeOne (a4_a1T9 <- Just (a3_a1T7 + 1), {Just, a3_a1T7, +}))
                (StmtTreeOne (b4_a1Ta <- Just (b3_a1T8 + 1),
                              {Just, b3_a1T8, +}))))))
  tree-cost = 4

-- Execution plan
(a1 | b1) ; ((a2 | b2) ; ((a3 | b3) ; (a4 | b4)))
