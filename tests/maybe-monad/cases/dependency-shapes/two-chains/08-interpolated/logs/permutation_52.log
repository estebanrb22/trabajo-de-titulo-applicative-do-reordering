                  a2_a1T5 <- Just (a1_a1T3 + 1), a3_a1T7 <- Just (a2_a1T5 + 1),
                  b4_a1Ta <- Just (b3_a1T8 + 1), a4_a1T9 <- Just (a3_a1T7 + 1)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (b1_a1T4 <- Just 10, {Just}))
          (StmtTreeOne (a1_a1T3 <- Just 1, {Just})))
       (StmtTreeBind
          (StmtTreeOne (b2_a1T6 <- Just (b1_a1T4 + 1), {Just, b1_a1T4, +}))
          (StmtTreeBind
             (StmtTreeApplicative
                (StmtTreeOne (b3_a1T8 <- Just (b2_a1T6 + 1), {Just, b2_a1T6, +}))
                (StmtTreeOne (a2_a1T5 <- Just (a1_a1T3 + 1), {Just, a1_a1T3, +})))
             (StmtTreeBind
                (StmtTreeApplicative
                   (StmtTreeOne (a3_a1T7 <- Just (a2_a1T5 + 1), {Just, a2_a1T5, +}))
                   (StmtTreeOne (b4_a1Ta <- Just (b3_a1T8 + 1), {Just, b3_a1T8, +})))
                (StmtTreeOne (a4_a1T9 <- Just (a3_a1T7 + 1),
                              {Just, a3_a1T7, +}))))))
  tree-cost = 5

