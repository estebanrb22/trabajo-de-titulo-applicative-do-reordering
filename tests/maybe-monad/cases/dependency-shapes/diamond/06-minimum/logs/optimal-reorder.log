-- Reordered do-notation
CD.do
  root <- Just 1
  a1 <- Just (root + 10)
  b1 <- Just (root + 20)
  a2 <- Just (a1 + 1)
  b2 <- Just (b1 + 1)
  join <- Just (a2 + b2)
  CD.return (root, a1, a2, b1, b2, join)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3, 4, 5, 6]
  statements  =  [root_a1T2 <- Just 1,
                  a1_a1T3 <- Just (root_a1T2 + 10), b1_a1T4 <- Just (root_a1T2 + 20),
                  a2_a1T5 <- Just (a1_a1T3 + 1), b2_a1T6 <- Just (b1_a1T4 + 1),
                  join_a1T7 <- Just (a2_a1T5 + b2_a1T6)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (root_a1T2 <- Just 1, {Just}))
       (StmtTreeBind
          (StmtTreeApplicative
             (StmtTreeOne (a1_a1T3 <- Just (root_a1T2 + 10),
                           {Just, root_a1T2, +}))
             (StmtTreeOne (b1_a1T4 <- Just (root_a1T2 + 20),
                           {Just, root_a1T2, +})))
          (StmtTreeBind
             (StmtTreeApplicative
                (StmtTreeOne (a2_a1T5 <- Just (a1_a1T3 + 1), {Just, a1_a1T3, +}))
                (StmtTreeOne (b2_a1T6 <- Just (b1_a1T4 + 1), {Just, b1_a1T4, +})))
             (StmtTreeOne (join_a1T7 <- Just (a2_a1T5 + b2_a1T6),
                           {Just, a2_a1T5, b2_a1T6, +})))))
  tree-cost = 4

-- Execution plan
root ; ((a1 | b1) ; ((a2 | b2) ; join))
