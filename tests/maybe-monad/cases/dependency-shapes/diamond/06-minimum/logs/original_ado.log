-- do-notation
do
  root <- Just 1
  a1 <- Just (root + 10)
  b1 <- Just (root + 20)
  a2 <- Just (a1 + 1)
  b2 <- Just (b1 + 1)
  join <- Just (a2 + b2)
  return (root, a1, a2, b1, b2, join)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeOne (root_a1S3 <- Just 1, {Just}))
     (StmtTreeBind
        (StmtTreeApplicative
           (StmtTreeOne (a1_a1S4 <- Just (root_a1S3 + 10),
                         {Just, root_a1S3, +}))
           (StmtTreeOne (b1_a1S5 <- Just (root_a1S3 + 20),
                         {Just, root_a1S3, +})))
        (StmtTreeBind
           (StmtTreeApplicative
              (StmtTreeOne (a2_a1S6 <- Just (a1_a1S4 + 1), {Just, a1_a1S4, +}))
              (StmtTreeOne (b2_a1S7 <- Just (b1_a1S5 + 1), {Just, b1_a1S5, +})))
           (StmtTreeOne (join_a1S8 <- Just (a2_a1S6 + b2_a1S7),
                         {Just, a2_a1S6, b2_a1S7, +})))))
  tree-cost = 4

-- Execution plan
root ; ((a1 | b1) ; ((a2 | b2) ; join))
