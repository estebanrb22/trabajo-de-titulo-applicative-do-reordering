-- Reordered do-notation
CD.do
  root <- Just 1
  b1 <- Just (root + 20)
  a1 <- Just (root + 10)
  join <- Just (a1 + b1)
  CD.return (root, a1, b1, join)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [1, 3, 2, 4]
  statements  =  [root_a1T3 <- Just 1,
                  b1_a1T5 <- Just (root_a1T3 + 20), a1_a1T4 <- Just (root_a1T3 + 10),
                  join_a1T6 <- Just (a1_a1T4 + b1_a1T5)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (root_a1T3 <- Just 1, {Just}))
       (StmtTreeBind
          (StmtTreeApplicative
             (StmtTreeOne (b1_a1T5 <- Just (root_a1T3 + 20),
                           {Just, root_a1T3, +}))
             (StmtTreeOne (a1_a1T4 <- Just (root_a1T3 + 10),
                           {Just, root_a1T3, +})))
          (StmtTreeOne (join_a1T6 <- Just (a1_a1T4 + b1_a1T5),
                        {Just, a1_a1T4, b1_a1T5, +}))))
  tree-cost = 3

-- Execution plan
root ; ((b1 | a1) ; join)
