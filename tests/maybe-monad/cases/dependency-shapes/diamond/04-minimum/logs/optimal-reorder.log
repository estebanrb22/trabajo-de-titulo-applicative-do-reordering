-- Reordered do-notation
CD.do
  root <- Just 1
  a1 <- Just (root + 10)
  b1 <- Just (root + 20)
  join <- Just (a1 + b1)
  CD.return (root, a1, b1, join)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3, 4]
  statements  =  [root_a1T2 <- Just 1,
                  a1_a1T3 <- Just (root_a1T2 + 10), b1_a1T4 <- Just (root_a1T2 + 20),
                  join_a1T5 <- Just (a1_a1T3 + b1_a1T4)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (root_a1T2 <- Just 1, {Just}))
       (StmtTreeBind
          (StmtTreeApplicative
             (StmtTreeOne (a1_a1T3 <- Just (root_a1T2 + 10),
                           {Just, root_a1T2, +}))
             (StmtTreeOne (b1_a1T4 <- Just (root_a1T2 + 20),
                           {Just, root_a1T2, +})))
          (StmtTreeOne (join_a1T5 <- Just (a1_a1T3 + b1_a1T4),
                        {Just, a1_a1T3, b1_a1T4, +}))))
  tree-cost = 3

-- Execution plan
root ; ((a1 | b1) ; join)
