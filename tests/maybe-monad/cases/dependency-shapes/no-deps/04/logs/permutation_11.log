-- Reordered do-notation
CD.do
  x2 <- Just 2
  x4 <- Just 4
  x3 <- Just 3
  x1 <- Just 1
  CD.return (x1 + x2 + x3 + x4)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  11
  index-order =  [2, 4, 3, 1]
  statements  =  [x2_a1T4 <- Just 2, x4_a1T6 <- Just 4,
                  x3_a1T5 <- Just 3, x1_a1T3 <- Just 1]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x2_a1T4 <- Just 2, {Just}))
       (StmtTreeOne (x4_a1T6 <- Just 4, {Just}))
       (StmtTreeOne (x3_a1T5 <- Just 3, {Just}))
       (StmtTreeOne (x1_a1T3 <- Just 1, {Just})))
  tree-cost = 1

-- Execution plan
x2 | x4 | x3 | x1
