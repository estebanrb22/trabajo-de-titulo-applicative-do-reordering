-- Reordered do-notation
CD.do
  x3 <- Just 3
  x2 <- Just 2
  x1 <- Just 1
  CD.return (x1 + x2 + x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  5
  index-order =  [3, 2, 1]
  statements  =  [x3_a1T5 <- Just 3, x2_a1T4 <- Just 2,
                  x1_a1T3 <- Just 1]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x3_a1T5 <- Just 3, {Just}))
       (StmtTreeOne (x2_a1T4 <- Just 2, {Just}))
       (StmtTreeOne (x1_a1T3 <- Just 1, {Just})))
  tree-cost = 1

-- Execution plan
x3 | x2 | x1
