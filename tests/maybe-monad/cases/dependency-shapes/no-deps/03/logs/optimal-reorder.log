-- Reordered do-notation
CD.do
  x1 <- Just 1
  x2 <- Just 2
  x3 <- Just 3
  CD.return (x1 + x2 + x3)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3]
  statements  =  [x1_a1T2 <- Just 1, x2_a1T3 <- Just 2,
                  x3_a1T4 <- Just 3]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x1_a1T2 <- Just 1, {Just}))
       (StmtTreeOne (x2_a1T3 <- Just 2, {Just}))
       (StmtTreeOne (x3_a1T4 <- Just 3, {Just})))
  tree-cost = 1

-- Execution plan
x1 | x2 | x3
