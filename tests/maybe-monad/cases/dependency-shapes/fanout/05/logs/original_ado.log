-- do-notation
do
  x1 <- Just 1
  x2 <- Just (x1 + 10)
  x3 <- Just (x1 + 20)
  x4 <- Just (x1 + 30)
  x5 <- Just (x1 + 40)
  return (x1, x2, x3, x4, x5)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeOne (x1_a1S3 <- Just 1, {Just}))
     (StmtTreeApplicative
        (StmtTreeOne (x2_a1S4 <- Just (x1_a1S3 + 10), {Just, x1_a1S3, +}))
        (StmtTreeOne (x3_a1S5 <- Just (x1_a1S3 + 20), {Just, x1_a1S3, +}))
        (StmtTreeOne (x4_a1S6 <- Just (x1_a1S3 + 30), {Just, x1_a1S3, +}))
        (StmtTreeOne (x5_a1S7 <- Just (x1_a1S3 + 40),
                      {Just, x1_a1S3, +}))))
  tree-cost = 2

-- Execution plan
x1 ; (x2 | x3 | x4 | x5)
