-- Reordered do-notation
CD.do
  x1 <- Just 1
  x2 <- Just (x1 + 10)
  x3 <- Just (x1 + 20)
  x4 <- Just (x1 + 30)
  x5 <- Just (x1 + 40)
  CD.return (x1, x2, x3, x4, x5)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3, 4, 5]
  statements  =  [x1_a1T2 <- Just 1, x2_a1T3 <- Just (x1_a1T2 + 10),
                  x3_a1T4 <- Just (x1_a1T2 + 20), x4_a1T5 <- Just (x1_a1T2 + 30),
                  x5_a1T6 <- Just (x1_a1T2 + 40)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (x1_a1T2 <- Just 1, {Just}))
       (StmtTreeApplicative
          (StmtTreeOne (x2_a1T3 <- Just (x1_a1T2 + 10), {Just, x1_a1T2, +}))
          (StmtTreeOne (x3_a1T4 <- Just (x1_a1T2 + 20), {Just, x1_a1T2, +}))
          (StmtTreeOne (x4_a1T5 <- Just (x1_a1T2 + 30), {Just, x1_a1T2, +}))
          (StmtTreeOne (x5_a1T6 <- Just (x1_a1T2 + 40),
                        {Just, x1_a1T2, +}))))
  tree-cost = 2

-- Execution plan
x1 ; (x2 | x3 | x4 | x5)
