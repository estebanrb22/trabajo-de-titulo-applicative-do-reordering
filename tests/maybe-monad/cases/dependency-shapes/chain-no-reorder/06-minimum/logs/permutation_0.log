-- Reordered do-notation
CD.do
  x1 <- Just 1
  x2 <- Just (x1 + 1)
  x3 <- Just (x2 + 1)
  x4 <- Just (x3 + 1)
  x5 <- Just (x4 + 1)
  x6 <- Just (x5 + 1)
  CD.return x6

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3, 4, 5, 6]
  statements  =  [x1_a1T3 <- Just 1, x2_a1T4 <- Just (x1_a1T3 + 1),
                  x3_a1T5 <- Just (x2_a1T4 + 1), x4_a1T6 <- Just (x3_a1T5 + 1),
                  x5_a1T7 <- Just (x4_a1T6 + 1), x6_a1T8 <- Just (x5_a1T7 + 1)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (x1_a1T3 <- Just 1, {Just}))
       (StmtTreeBind
          (StmtTreeOne (x2_a1T4 <- Just (x1_a1T3 + 1), {Just, x1_a1T3, +}))
          (StmtTreeBind
             (StmtTreeOne (x3_a1T5 <- Just (x2_a1T4 + 1), {Just, x2_a1T4, +}))
             (StmtTreeBind
                (StmtTreeOne (x4_a1T6 <- Just (x3_a1T5 + 1), {Just, x3_a1T5, +}))
                (StmtTreeBind
                   (StmtTreeOne (x5_a1T7 <- Just (x4_a1T6 + 1), {Just, x4_a1T6, +}))
                   (StmtTreeOne (x6_a1T8 <- Just (x5_a1T7 + 1),
                                 {Just, x5_a1T7, +})))))))
  tree-cost = 6

-- Execution plan
x1 ; (x2 ; (x3 ; (x4 ; (x5 ; x6))))
