-- Original program
CD.do
  x1 <- Just 1
  x2 <- Just (x1 + 1)
  x3 <- Just (x2 + 1)
  x4 <- Just (x3 + 1)
  x5 <- Just (x4 + 1)
  x6 <- Just (x5 + 1)
  CD.return x6

-- Internal representation with free variables by statement
ppsfa
  [(x1_a1T2 <- Just 1, {Just}),
   (x2_a1T3 <- Just (x1_a1T2 + 1), {Just, x1_a1T2, +}),
   (x3_a1T4 <- Just (x2_a1T3 + 1), {Just, x2_a1T3, +}),
   (x4_a1T5 <- Just (x3_a1T4 + 1), {Just, x3_a1T4, +}),
   (x5_a1T6 <- Just (x4_a1T5 + 1), {Just, x4_a1T5, +}),
   (x6_a1T7 <- Just (x5_a1T6 + 1), {Just, x5_a1T6, +}),
   (CD.return x6_a1T7, {x6_a1T7, CD.return})]

