-- do-notation
do
  x1 <- Just 1
  x2 <- Just (x1 + 1)
  x3 <- Just (x1 + x2 + 1)
  x4 <- Just (x1 + x2 + x3 + 1)
  x5 <- Just (x1 + x2 + x3 + x4 + 1)
  x6 <- Just (x1 + x2 + x3 + x4 + x5 + 1)
  return x6

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeOne (x1_a1S3 <- Just 1, {Just}))
     (StmtTreeBind
        (StmtTreeOne (x2_a1S4 <- Just (x1_a1S3 + 1), {Just, x1_a1S3, +}))
        (StmtTreeBind
           (StmtTreeOne (x3_a1S5 <- Just (x1_a1S3 + x2_a1S4 + 1),
                         {Just, x1_a1S3, x2_a1S4, +}))
           (StmtTreeBind
              (StmtTreeOne (x4_a1S6 <- Just (x1_a1S3 + x2_a1S4 + x3_a1S5 + 1),
                            {Just, x1_a1S3, x2_a1S4, x3_a1S5, +}))
              (StmtTreeBind
                 (StmtTreeOne (x5_a1S7 <- Just
                                            (x1_a1S3 + x2_a1S4 + x3_a1S5 + x4_a1S6 + 1),
                               {Just, x1_a1S3, x2_a1S4, x3_a1S5, x4_a1S6, +}))
                 (StmtTreeOne (x6_a1S8 <- Just
                                            (x1_a1S3 + x2_a1S4 + x3_a1S5 + x4_a1S6 + x5_a1S7 + 1),
                               {Just, x1_a1S3, x2_a1S4, x3_a1S5, x4_a1S6, x5_a1S7, +})))))))

-- Execution plan
x1 ; (x2 ; (x3 ; (x4 ; (x5 ; x6))))
