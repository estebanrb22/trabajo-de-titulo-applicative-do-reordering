-- Reordered do-notation
CD.do
  x1 <- Just 1
  x2 <- Just (x1 + 1)
  x3 <- Just (x2 + 1)
  x4 <- Just (x3 + 1)
  CD.return (x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3, 4]
  statements  =  [x1_a1T3 <- Just 1, x2_a1T4 <- Just (x1_a1T3 + 1),
                  x3_a1T5 <- Just (x2_a1T4 + 1), x4_a1T6 <- Just (x3_a1T5 + 1)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (x1_a1T3 <- Just 1, {Just}))
       (StmtTreeBind
          (StmtTreeOne (x2_a1T4 <- Just (x1_a1T3 + 1), {Just, x1_a1T3, +}))
          (StmtTreeBind
             (StmtTreeOne (x3_a1T5 <- Just (x2_a1T4 + 1), {Just, x2_a1T4, +}))
             (StmtTreeOne (x4_a1T6 <- Just (x3_a1T5 + 1),
                           {Just, x3_a1T5, +})))))
  tree-cost = 4

-- Execution plan
x1 ; (x2 ; (x3 ; x4))
