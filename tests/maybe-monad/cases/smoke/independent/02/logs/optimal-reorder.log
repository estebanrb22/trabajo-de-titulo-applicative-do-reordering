-- Reordered do-notation
CD.do
  x1 <- Just 10
  x2 <- Just 5
  CD.return (x1 + x2)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2]
  statements  =  [x1_a1T1 <- Just 10, x2_a1T2 <- Just 5]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x1_a1T1 <- Just 10, {Just}))
       (StmtTreeOne (x2_a1T2 <- Just 5, {Just})))
  tree-cost = 1

-- Execution plan
x1 | x2
