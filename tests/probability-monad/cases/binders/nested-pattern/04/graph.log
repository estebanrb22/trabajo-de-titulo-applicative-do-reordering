-- Original program
CD.do
  ((x1, x2), (x3, x4)) <- Dist.uniform [((1, 10), (100, 1000)), ((2, 20), (200, 2000))]
  x5 <- Dist.uniform [x1 + x3, x1 + x3 + 1]
  x6 <- Dist.uniform [x2 + x4, x2 + x4 + 1]
  x7 <- Dist.uniform [x5 + x6, x5 + x6 + 1]
  CD.return (x1, x2, x3, x4, x5, x6, x7)

-- Internal representation with free variables by statement
ppsfa
  [(((x1_a1Y4, x2_a1Y5), (x3_a1Y6, x4_a1Y7)) <- Dist.uniform [((1, 10), (100, 1000)), ((2, 20), (200, 2000))], {Dist.uniform}),
   (x5_a1Y8 <- Dist.uniform [x1_a1Y4 + x3_a1Y6, x1_a1Y4 + x3_a1Y6 + 1], {x1_a1Y4, x3_a1Y6, +, Dist.uniform}),
   (x6_a1Y9 <- Dist.uniform [x2_a1Y5 + x4_a1Y7, x2_a1Y5 + x4_a1Y7 + 1], {x2_a1Y5, x4_a1Y7, +, Dist.uniform}),
   (x7_a1Ya <- Dist.uniform [x5_a1Y8 + x6_a1Y9, x5_a1Y8 + x6_a1Y9 + 1], {x5_a1Y8, x6_a1Y9, +, Dist.uniform}),
   (CD.return (x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7, x5_a1Y8, x6_a1Y9, x7_a1Ya), {x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7, x5_a1Y8, x6_a1Y9, x7_a1Ya, CD.return})]

