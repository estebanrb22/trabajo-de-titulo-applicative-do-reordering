-- Original program
CD.do
  ~[x1] <- Dist.certainly []
  x2 <- Dist.uniform [10, 20]
  x3 <- Dist.uniform [x2 + 1, x2 + 2]
  CD.return (x2, x3)

-- Internal representation with free variables by statement
ppsfa
  [(~[x1_a1Y4] <- Dist.certainly [], {[], Dist.certainly}),
   (x2_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}),
   (x3_a1Y6 <- Dist.uniform [x2_a1Y5 + 1, x2_a1Y5 + 2], {x2_a1Y5, +, Dist.uniform}),
   (CD.return (x2_a1Y5, x3_a1Y6), {x2_a1Y5, x3_a1Y6, CD.return})]

