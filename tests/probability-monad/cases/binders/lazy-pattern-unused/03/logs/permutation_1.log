-- Reordered do-notation
CD.do
  x2 <- Dist.uniform [10, 20]
  ~[x1] <- Dist.certainly []
  x3 <- Dist.uniform [x2 + 1, x2 + 2]
  CD.return (x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [2, 1, 3]
  statements  =  [x2_a1Y5 <- Dist.uniform [10, 20],
                  ~[x1_a1Y4] <- Dist.certainly [],
                  x3_a1Y6 <- Dist.uniform [x2_a1Y5 + 1, x2_a1Y5 + 2]]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x2_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}))
          (StmtTreeOne (~[x1_a1Y4] <- Dist.certainly [],
                        {[], Dist.certainly})))
       (StmtTreeOne (x3_a1Y6 <- Dist.uniform [x2_a1Y5 + 1, x2_a1Y5 + 2],
                     {x2_a1Y5, +, Dist.uniform})))
  tree-cost = 2

-- Execution plan
(x2 | ~[x1]) ; x3
