-- do-notation
do
  ~[x1] <- Dist.certainly []
  x2 <- Dist.uniform [10, 20]
  x3 <- Dist.uniform [x2 + 1, x2 + 2]
  return (x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeOne (~[x1_a1X5] <- Dist.certainly [],
                   {[], Dist.certainly}))
     (StmtTreeBind
        (StmtTreeOne (x2_a1X6 <- Dist.uniform [10, 20], {Dist.uniform}))
        (StmtTreeOne (x3_a1X7 <- Dist.uniform [x2_a1X6 + 1, x2_a1X6 + 2],
                      {x2_a1X6, +, Dist.uniform}))))
  tree-cost = 2

-- Execution plan
~[x1] | (x2 ; x3)
