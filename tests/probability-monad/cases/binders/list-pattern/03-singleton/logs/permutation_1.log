-- Reordered do-notation
CD.do
  x2 <- Dist.uniform [1, 2]
  [x1] <- Dist.uniform [[10], [20]]
  x3 <- Dist.uniform [x1 + x2, x1 + x2 + 100]
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [2, 1, 3]
  statements  =  [x2_a1Y5 <- Dist.uniform [1, 2],
                  [x1_a1Y4] <- Dist.uniform [[10], [20]],
                  x3_a1Y6 <- Dist.uniform
                               [x1_a1Y4 + x2_a1Y5, x1_a1Y4 + x2_a1Y5 + 100]]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (x2_a1Y5 <- Dist.uniform [1, 2], {Dist.uniform}))
       (StmtTreeBind
          (StmtTreeOne ([x1_a1Y4] <- Dist.uniform [[10], [20]],
                        {Dist.uniform}))
          (StmtTreeOne (x3_a1Y6 <- Dist.uniform
                                     [x1_a1Y4 + x2_a1Y5, x1_a1Y4 + x2_a1Y5 + 100],
                        {x1_a1Y4, x2_a1Y5, +, Dist.uniform}))))
  tree-cost = 3

-- Execution plan
x2 ; ([x1] ; x3)
