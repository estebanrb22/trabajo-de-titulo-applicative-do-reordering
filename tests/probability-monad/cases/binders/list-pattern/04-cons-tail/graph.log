-- Original program
CD.do
  (x1:x2:xs) <- Dist.uniform [[1, 10, 100], [2, 20, 200, 2000]]
  x3 <- Dist.uniform [x1 + x2, x1 + x2 + 1]
  x4 <- Dist.uniform [sum xs, sum xs + 1]
  x5 <- Dist.uniform [x3 + x4, x3 + x4 + 1]
  CD.return (x1, x2, xs, x3, x4, x5)

-- Internal representation with free variables by statement
ppsfa
  [((x1_a1Y4 : x2_a1Y5 : xs_a1Y6) <- Dist.uniform [[1, 10, 100], [2, 20, 200, 2000]], {Dist.uniform}),
   (x3_a1Y7 <- Dist.uniform [x1_a1Y4 + x2_a1Y5, x1_a1Y4 + x2_a1Y5 + 1], {x1_a1Y4, x2_a1Y5, +, Dist.uniform}),
   (x4_a1Y8 <- Dist.uniform [sum xs_a1Y6, sum xs_a1Y6 + 1], {xs_a1Y6, sum, +, Dist.uniform}),
   (x5_a1Y9 <- Dist.uniform [x3_a1Y7 + x4_a1Y8, x3_a1Y7 + x4_a1Y8 + 1], {x3_a1Y7, x4_a1Y8, +, Dist.uniform}),
   (CD.return (x1_a1Y4, x2_a1Y5, xs_a1Y6, x3_a1Y7, x4_a1Y8, x5_a1Y9), {x1_a1Y4, x2_a1Y5, xs_a1Y6, x3_a1Y7, x4_a1Y8, x5_a1Y9, CD.return})]

-- Precedence graph adjacency list
1 -> {2, 3}
2 -> {4}
3 -> {4}
4 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {2}
x2: 1 -> {2}
xs: 1 -> {3}
x3: 2 -> {4}
x4: 3 -> {4}
