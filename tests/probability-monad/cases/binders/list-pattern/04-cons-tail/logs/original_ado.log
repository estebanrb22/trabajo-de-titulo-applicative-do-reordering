-- do-notation
do
  (x1:x2:xs) <- Dist.uniform [[1, 10, 100], [2, 20, 200, 2000]]
  x3 <- Dist.uniform [x1 + x2, x1 + x2 + 1]
  x4 <- Dist.uniform [sum xs, sum xs + 1]
  x5 <- Dist.uniform [x3 + x4, x3 + x4 + 1]
  return (x1, x2, xs, x3, x4, x5)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeOne ((x1_a1X5 : x2_a1X6 : xs_a1X7) <- Dist.uniform
                                                      [[1, 10, 100], [2, 20, 200, 2000]],
                   {Dist.uniform}))
     (StmtTreeBind
        (StmtTreeApplicative
           (StmtTreeOne (x3_a1X8 <- Dist.uniform
                                      [x1_a1X5 + x2_a1X6, x1_a1X5 + x2_a1X6 + 1],
                         {x1_a1X5, x2_a1X6, +, Dist.uniform}))
           (StmtTreeOne (x4_a1X9 <- Dist.uniform
                                      [sum xs_a1X7, sum xs_a1X7 + 1],
                         {xs_a1X7, sum, +, Dist.uniform})))
        (StmtTreeOne (x5_a1Xa <- Dist.uniform
                                   [x3_a1X8 + x4_a1X9, x3_a1X8 + x4_a1X9 + 1],
                      {x3_a1X8, x4_a1X9, +, Dist.uniform}))))
  tree-cost = 3

-- Execution plan
(x1:x2:xs) ; ((x3 | x4) ; x5)
