-- Reordered do-notation
CD.do
  pair@(x1, _) <- Dist.uniform [(1, 10), (2, 20)]
  x2 <- Dist.uniform [fst pair + 20, fst pair + 30]
  x3 <- Dist.uniform [x1 + 30, x1 + 40]
  x4 <- Dist.uniform [x2 + x3, x2 + x3 + 1]
  CD.return (pair, x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  0
  index-order =  [1, 2, 3, 4]
  statements  =  [pair_a1Y4@(x1_a1Y5, _) <- Dist.uniform
                                              [(1, 10), (2, 20)],
                  x2_a1Y6 <- Dist.uniform [fst pair_a1Y4 + 20, fst pair_a1Y4 + 30],
                  x3_a1Y7 <- Dist.uniform [x1_a1Y5 + 30, x1_a1Y5 + 40],
                  x4_a1Y8 <- Dist.uniform [x2_a1Y6 + x3_a1Y7, x2_a1Y6 + x3_a1Y7 + 1]]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (pair_a1Y4@(x1_a1Y5, _) <- Dist.uniform
                                                 [(1, 10), (2, 20)],
                     {Dist.uniform}))
       (StmtTreeBind
          (StmtTreeApplicative
             (StmtTreeOne (x2_a1Y6 <- Dist.uniform
                                        [fst pair_a1Y4 + 20, fst pair_a1Y4 + 30],
                           {pair_a1Y4, fst, +, Dist.uniform}))
             (StmtTreeOne (x3_a1Y7 <- Dist.uniform [x1_a1Y5 + 30, x1_a1Y5 + 40],
                           {x1_a1Y5, +, Dist.uniform})))
          (StmtTreeOne (x4_a1Y8 <- Dist.uniform
                                     [x2_a1Y6 + x3_a1Y7, x2_a1Y6 + x3_a1Y7 + 1],
                        {x2_a1Y6, x3_a1Y7, +, Dist.uniform}))))
  tree-cost = 3

-- Execution plan
pair@(x1, _) ; ((x2 | x3) ; x4)
