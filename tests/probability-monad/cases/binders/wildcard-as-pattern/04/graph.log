-- Original program
CD.do
  pair@(x1, _) <- Dist.uniform [(1, 10), (2, 20)]
  x2 <- Dist.uniform [fst pair + 20, fst pair + 30]
  x3 <- Dist.uniform [x1 + 30, x1 + 40]
  x4 <- Dist.uniform [x2 + x3, x2 + x3 + 1]
  CD.return (pair, x1, x2, x3, x4)

-- Internal representation with free variables by statement
ppsfa
  [(pair_a1Y4@(x1_a1Y5, _) <- Dist.uniform [(1, 10), (2, 20)], {Dist.uniform}),
   (x2_a1Y6 <- Dist.uniform [fst pair_a1Y4 + 20, fst pair_a1Y4 + 30], {pair_a1Y4, fst, +, Dist.uniform}),
   (x3_a1Y7 <- Dist.uniform [x1_a1Y5 + 30, x1_a1Y5 + 40], {x1_a1Y5, +, Dist.uniform}),
   (x4_a1Y8 <- Dist.uniform [x2_a1Y6 + x3_a1Y7, x2_a1Y6 + x3_a1Y7 + 1], {x2_a1Y6, x3_a1Y7, +, Dist.uniform}),
   (CD.return (pair_a1Y4, x1_a1Y5, x2_a1Y6, x3_a1Y7, x4_a1Y8), {pair_a1Y4, x1_a1Y5, x2_a1Y6, x3_a1Y7, x4_a1Y8, CD.return})]

-- Precedence graph adjacency list
1 -> {2, 3}
2 -> {4}
3 -> {4}
4 -> {}

-- Precedence graph RAW dependencies grouped by binder
pair: 1 -> {2}
x1: 1 -> {3}
x2: 2 -> {4}
x3: 3 -> {4}
