-- Original program
CD.do
  (x1, x2) <- Dist.uniform [(1, 10), (2, 20)]
  x3 <- Dist.uniform [x1 + 1, x1 + 2]
  x4 <- Dist.uniform [x2 + 1, x2 + 2]
  CD.return (x1, x2, x3, x4)

-- Internal representation with free variables by statement
ppsfa
  [((x1_a1Y4, x2_a1Y5) <- Dist.uniform [(1, 10), (2, 20)], {Dist.uniform}),
   (x3_a1Y6 <- Dist.uniform [x1_a1Y4 + 1, x1_a1Y4 + 2], {x1_a1Y4, +, Dist.uniform}),
   (x4_a1Y7 <- Dist.uniform [x2_a1Y5 + 1, x2_a1Y5 + 2], {x2_a1Y5, +, Dist.uniform}),
   (CD.return (x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7), {x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7, CD.return})]

-- Precedence graph adjacency list
1 -> {2, 3}
2 -> {}
3 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {2}
x2: 1 -> {3}
