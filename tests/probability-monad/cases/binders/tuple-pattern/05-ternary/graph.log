-- Original program
CD.do
  (x1, x2, x3) <- Dist.uniform [(1, 10, 100), (2, 20, 200)]
  x4 <- Dist.uniform [x1 + 1, x1 + 2]
  x5 <- Dist.uniform [x2 + 1, x2 + 2]
  x6 <- Dist.uniform [x3 + 1, x3 + 2]
  x7 <- Dist.uniform [x4 + x5 + x6, x4 + x5 + x6 + 1]
  CD.return (x1, x2, x3, x4, x5, x6, x7)

-- Internal representation with free variables by statement
ppsfa
  [((x1_a1Y4, x2_a1Y5, x3_a1Y6) <- Dist.uniform [(1, 10, 100), (2, 20, 200)], {Dist.uniform}),
   (x4_a1Y7 <- Dist.uniform [x1_a1Y4 + 1, x1_a1Y4 + 2], {x1_a1Y4, +, Dist.uniform}),
   (x5_a1Y8 <- Dist.uniform [x2_a1Y5 + 1, x2_a1Y5 + 2], {x2_a1Y5, +, Dist.uniform}),
   (x6_a1Y9 <- Dist.uniform [x3_a1Y6 + 1, x3_a1Y6 + 2], {x3_a1Y6, +, Dist.uniform}),
   (x7_a1Ya <- Dist.uniform [x4_a1Y7 + x5_a1Y8 + x6_a1Y9, x4_a1Y7 + x5_a1Y8 + x6_a1Y9 + 1], {x4_a1Y7, x5_a1Y8, x6_a1Y9, +, Dist.uniform}),
   (CD.return (x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7, x5_a1Y8, x6_a1Y9, x7_a1Ya), {x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7, x5_a1Y8, x6_a1Y9, x7_a1Ya, CD.return})]

-- Precedence graph adjacency list
1 -> {2, 3, 4}
2 -> {5}
3 -> {5}
4 -> {5}
5 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {2}
x2: 1 -> {3}
x3: 1 -> {4}
x4: 2 -> {5}
x5: 3 -> {5}
x6: 4 -> {5}
