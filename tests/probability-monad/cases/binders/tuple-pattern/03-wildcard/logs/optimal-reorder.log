-- Reordered do-notation
CD.do
  (_, x1, x2) <- Dist.uniform [(0, 10, 100), (999, 20, 200)]
  x3 <- Dist.uniform [x1 + 1, x1 + 2]
  x4 <- Dist.uniform [x2 + 1, x2 + 2]
  CD.return (x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3]
  statements  =  [(_, x1_a1Y4, x2_a1Y5) <- Dist.uniform
                                             [(0, 10, 100), (999, 20, 200)],
                  x3_a1Y6 <- Dist.uniform [x1_a1Y4 + 1, x1_a1Y4 + 2],
                  x4_a1Y7 <- Dist.uniform [x2_a1Y5 + 1, x2_a1Y5 + 2]]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne ((_, x1_a1Y4, x2_a1Y5) <- Dist.uniform
                                                [(0, 10, 100), (999, 20, 200)],
                     {Dist.uniform}))
       (StmtTreeApplicative
          (StmtTreeOne (x3_a1Y6 <- Dist.uniform [x1_a1Y4 + 1, x1_a1Y4 + 2],
                        {x1_a1Y4, +, Dist.uniform}))
          (StmtTreeOne (x4_a1Y7 <- Dist.uniform [x2_a1Y5 + 1, x2_a1Y5 + 2],
                        {x2_a1Y5, +, Dist.uniform}))))
  tree-cost = 2

-- Execution plan
(_, x1, x2) ; (x3 | x4)
