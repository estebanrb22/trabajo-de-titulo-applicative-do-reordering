-- Reordered do-notation
CD.do
  x1 <- Dist.uniform [1, 2]
  x2 <- if x1 == 1
  then Dist.Cons [(10, 1 / 4), (20, 3 / 4)]
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3]
  statements  =  [x1_a1Y4 <- Dist.uniform [1, 2],
                  x2_a1Y5 <- if x1_a1Y4 == 1 then
                                 Dist.Cons [(10, 1 / 4), (20, 3 / 4)]
                             else
                                 Dist.Cons [(10, 3 / 4), (20, 1 / 4)],
                  x3_a1Y6 <- Dist.uniform [100, 200]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeBind
          (StmtTreeOne (x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}))
          (StmtTreeOne (x2_a1Y5 <- if x1_a1Y4 == 1 then
                                       Dist.Cons [(10, 1 / 4), (20, 3 / 4)]
                                   else
                                       Dist.Cons [(10, 3 / 4), (20, 1 / 4)],
                        {==, x1_a1Y4, /, Dist.Cons})))
       (StmtTreeOne (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform})))
  tree-cost = 2

-- Execution plan
(x1 ; x2) | stmt3
