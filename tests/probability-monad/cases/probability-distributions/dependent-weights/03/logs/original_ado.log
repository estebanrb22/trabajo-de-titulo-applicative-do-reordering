-- do-notation
do
  x1 <- Dist.uniform [1, 2]
  x2 <- if x1 == 1
  then Dist.Cons [(10, 1 / 4), (20, 3 / 4)]
  else Dist.Cons [(10, 3 / 4), (20, 1 / 4)]
  x3 <- Dist.uniform [100, 200]
  return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeBind
        (StmtTreeOne (x1_a1X5 <- Dist.uniform [1, 2], {Dist.uniform}))
        (StmtTreeOne (x2_a1X6 <- if x1_a1X5 == 1 then
                                     Dist.Cons [(10, 1 / 4), (20, 3 / 4)]
                                 else
                                     Dist.Cons [(10, 3 / 4), (20, 1 / 4)],
                      {==, x1_a1X5, /, Dist.Cons})))
     (StmtTreeOne (x3_a1X7 <- Dist.uniform [100, 200], {Dist.uniform})))
  tree-cost = 2

-- Execution plan
(x1 ; x2) | stmt3
