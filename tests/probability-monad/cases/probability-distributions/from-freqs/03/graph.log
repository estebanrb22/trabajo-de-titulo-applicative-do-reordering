-- Original program
CD.do
  x1 <- Dist.fromFreqs [(1, 1), (2, 3)]
  x2 <- Dist.fromFreqs [(10, 2), (20, 1)]
  x3 <- Dist.uniform [100, 200]
  CD.return (x1, x2, x3)

-- Internal representation with free variables by statement
ppsfa
  [(x1_a1Y4 <- Dist.fromFreqs [(1, 1), (2, 3)], {Dist.fromFreqs}),
   (x2_a1Y5 <- Dist.fromFreqs [(10, 2), (20, 1)], {Dist.fromFreqs}),
   (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform}),
   (CD.return (x1_a1Y4, x2_a1Y5, x3_a1Y6), {x1_a1Y4, x2_a1Y5, x3_a1Y6, CD.return})]

