-- Reordered do-notation
CD.do
  x2 <- Dist.fromFreqs [(10, 2), (20, 1)]
  x3 <- Dist.uniform [100, 200]
  x1 <- Dist.fromFreqs [(1, 1), (2, 3)]
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  3
  index-order =  [2, 3, 1]
  statements  =  [x2_a1Y5 <- Dist.fromFreqs [(10, 2), (20, 1)],
                  x3_a1Y6 <- Dist.uniform [100, 200],
                  x1_a1Y4 <- Dist.fromFreqs [(1, 1), (2, 3)]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x2_a1Y5 <- Dist.fromFreqs [(10, 2), (20, 1)],
                     {Dist.fromFreqs}))
       (StmtTreeOne (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform}))
       (StmtTreeOne (x1_a1Y4 <- Dist.fromFreqs [(1, 1), (2, 3)],
                     {Dist.fromFreqs})))
  tree-cost = 1

-- Execution plan
x2 | x3 | x1
