-- do-notation
do
  x1 <- Dist.uniform [1, 2]
  x2 <- if x1 == 1
  then Dist.choose (1 / 4) 10 20
  else Dist.choose (3 / 4) 10 20
  x3 <- Dist.uniform [100, 200]
  return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeBind
        (StmtTreeOne (x1_a1X5 <- Dist.uniform [1, 2], {Dist.uniform}))
        (StmtTreeOne (x2_a1X6 <- if x1_a1X5 == 1 then
                                     Dist.choose (1 / 4) 10 20
                                 else
                                     Dist.choose (3 / 4) 10 20,
                      {==, x1_a1X5, /, Dist.choose})))
     (StmtTreeOne (x3_a1X7 <- Dist.uniform [100, 200], {Dist.uniform})))
  tree-cost = 2

-- Execution plan
(x1 ; x2) | stmt3
