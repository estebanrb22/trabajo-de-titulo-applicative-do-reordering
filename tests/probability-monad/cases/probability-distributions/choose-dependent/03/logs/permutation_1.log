-- Reordered do-notation
CD.do
  x1 <- Dist.uniform [1, 2]
  then Dist.choose (1 / 4) 10 20
  x2 <- if x1 == 1
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [1, 3, 2]
  statements  =  [x1_a1Y4 <- Dist.uniform [1, 2],
                  x3_a1Y6 <- Dist.uniform [100, 200],
                  x2_a1Y5 <- if x1_a1Y4 == 1 then
                                 Dist.choose (1 / 4) 10 20
                             else
                                 Dist.choose (3 / 4) 10 20]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}))
          (StmtTreeOne (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform})))
       (StmtTreeOne (x2_a1Y5 <- if x1_a1Y4 == 1 then
                                    Dist.choose (1 / 4) 10 20
                                else
                                    Dist.choose (3 / 4) 10 20,
                     {==, x1_a1Y4, /, Dist.choose})))
  tree-cost = 2

-- Execution plan
(x1 | stmt3) ; x2
