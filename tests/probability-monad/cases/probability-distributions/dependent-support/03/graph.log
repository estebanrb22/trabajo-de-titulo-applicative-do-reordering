-- Original program
CD.do
  x1 <- Dist.uniform [1, 2]
  x2 <- if x1 == 1
  then Dist.certainly 10
  else Dist.uniform [20, 30]
  x3 <- Dist.uniform [100, 200]
  CD.return (x1, x2, x3)

-- Internal representation with free variables by statement
ppsfa
  [(x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}),
   (x2_a1Y5 <- if x1_a1Y4 == 1 then Dist.certainly 10 else Dist.uniform [20, 30], {==, x1_a1Y4, Dist.certainly, Dist.uniform}),
   (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform}),
   (CD.return (x1_a1Y4, x2_a1Y5, x3_a1Y6), {x1_a1Y4, x2_a1Y5, x3_a1Y6, CD.return})]

-- Precedence graph adjacency list
1 -> {2}
2 -> {}
3 -> {}
4 -> {}
5 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {2}
