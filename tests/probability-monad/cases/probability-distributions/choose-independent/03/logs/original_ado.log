-- do-notation
do
  x1 <- Dist.choose (1 / 4) 1 2
  x2 <- Dist.choose (2 / 3) 10 20
  x3 <- Dist.uniform [100, 200]
  return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeOne (x1_a1X5 <- Dist.choose (1 / 4) 1 2,
                   {/, Dist.choose}))
     (StmtTreeOne (x2_a1X6 <- Dist.choose (2 / 3) 10 20,
                   {/, Dist.choose}))
     (StmtTreeOne (x3_a1X7 <- Dist.uniform [100, 200], {Dist.uniform})))
  tree-cost = 1

-- Execution plan
x1 | x2 | x3
