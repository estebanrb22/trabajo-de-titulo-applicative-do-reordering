-- Reordered do-notation
CD.do
  x2 <- Dist.choose (2 / 3) 10 20
  x1 <- Dist.choose (1 / 4) 1 2
  x3 <- Dist.uniform [100, 200]
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  2
  index-order =  [2, 1, 3]
  statements  =  [x2_a1Y5 <- Dist.choose (2 / 3) 10 20,
                  x1_a1Y4 <- Dist.choose (1 / 4) 1 2,
                  x3_a1Y6 <- Dist.uniform [100, 200]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x2_a1Y5 <- Dist.choose (2 / 3) 10 20,
                     {/, Dist.choose}))
       (StmtTreeOne (x1_a1Y4 <- Dist.choose (1 / 4) 1 2,
                     {/, Dist.choose}))
       (StmtTreeOne (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform})))
  tree-cost = 1

-- Execution plan
x2 | x1 | x3
