-- Reordered do-notation
CD.do
  x2 <- Dist.uniform [10, 11]
  x1 <- Dist.uniform [1, 2]
  CD.return (x1 + x2)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [2, 1]
  statements  =  [x2_a1Y5 <- Dist.uniform [10, 11],
                  x1_a1Y4 <- Dist.uniform [1, 2]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x2_a1Y5 <- Dist.uniform [10, 11], {Dist.uniform}))
       (StmtTreeOne (x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform})))
  tree-cost = 1

-- Execution plan
x2 | x1
