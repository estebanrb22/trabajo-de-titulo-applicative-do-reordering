-- Reordered do-notation
CD.do
  x1 <- Dist.uniform [1, 2]
  x2 <- Dist.uniform [10, 11]
  CD.return (x1 + x2)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2]
  statements  =  [x1_a1Y4 <- Dist.uniform [1, 2],
                  x2_a1Y5 <- Dist.uniform [10, 11]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}))
       (StmtTreeOne (x2_a1Y5 <- Dist.uniform [10, 11], {Dist.uniform})))
  tree-cost = 1

-- Execution plan
x1 | x2
