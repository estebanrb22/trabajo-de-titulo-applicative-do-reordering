-- Reordered do-notation
CD.do
  x1 <- Dist.Cons [(1, 1 / 4), (2, 3 / 4)]
  x2 <- Dist.Cons [(10, 2 / 3), (20, 1 / 3)]
  x3 <- Dist.uniform [100, 200]
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3]
  statements  =  [x1_a1Y4 <- Dist.Cons [(1, 1 / 4), (2, 3 / 4)],
                  x2_a1Y5 <- Dist.Cons [(10, 2 / 3), (20, 1 / 3)],
                  x3_a1Y6 <- Dist.uniform [100, 200]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x1_a1Y4 <- Dist.Cons [(1, 1 / 4), (2, 3 / 4)],
                     {/, Dist.Cons}))
       (StmtTreeOne (x2_a1Y5 <- Dist.Cons [(10, 2 / 3), (20, 1 / 3)],
                     {/, Dist.Cons}))
       (StmtTreeOne (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform})))
  tree-cost = 1

-- Execution plan
x1 | x2 | x3
