-- Reordered do-notation
CD.do
  x3 <- Dist.uniform [100, 200]
  x2 <- Dist.Cons [(10, 2 / 3), (20, 1 / 3)]
  x1 <- Dist.Cons [(1, 1 / 4), (2, 3 / 4)]
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  5
  index-order =  [3, 2, 1]
  statements  =  [x3_a1Y6 <- Dist.uniform [100, 200],
                  x2_a1Y5 <- Dist.Cons [(10, 2 / 3), (20, 1 / 3)],
                  x1_a1Y4 <- Dist.Cons [(1, 1 / 4), (2, 3 / 4)]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform}))
       (StmtTreeOne (x2_a1Y5 <- Dist.Cons [(10, 2 / 3), (20, 1 / 3)],
                     {/, Dist.Cons}))
       (StmtTreeOne (x1_a1Y4 <- Dist.Cons [(1, 1 / 4), (2, 3 / 4)],
                     {/, Dist.Cons})))
  tree-cost = 1

-- Execution plan
x3 | x2 | x1
