-- do-notation
do
  x1 <- Dist.Cons [(1, 1 / 4), (1, 1 / 4), (2, 1 / 2)]
  x2 <- Dist.uniform [10, 20]
  return (x1, x2)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeOne (x1_a1X5 <- Dist.Cons
                                [(1, 1 / 4), (1, 1 / 4), (2, 1 / 2)],
                   {/, Dist.Cons}))
     (StmtTreeOne (x2_a1X6 <- Dist.uniform [10, 20], {Dist.uniform})))
  tree-cost = 1

-- Execution plan
x1 | x2
