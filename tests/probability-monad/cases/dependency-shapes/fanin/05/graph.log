-- Original program
CD.do
  x1 <- Dist.uniform [1, 2]
  x2 <- Dist.uniform [10, 20]
  x3 <- Dist.uniform [100, 200]
  x4 <- Dist.uniform [1000, 2000]
  x5 <- Dist.uniform [x1 + x2 + x3 + x4 + 10000, x1 + x2 + x3 + x4 + 20000]
  CD.return (x1, x2, x3, x4, x5)

-- Internal representation with free variables by statement
ppsfa
  [(x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}),
   (x2_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}),
   (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform}),
   (x4_a1Y7 <- Dist.uniform [1000, 2000], {Dist.uniform}),
   (x5_a1Y8 <- Dist.uniform [x1_a1Y4 + x2_a1Y5 + x3_a1Y6 + x4_a1Y7 + 10000, x1_a1Y4 + x2_a1Y5 + x3_a1Y6 + x4_a1Y7 + 20000], {x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7, +, Dist.uniform}),
   (CD.return (x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7, x5_a1Y8), {x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7, x5_a1Y8, CD.return})]

-- Precedence graph adjacency list
1 -> {5}
2 -> {5}
3 -> {5}
4 -> {5}
5 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {5}
x2: 2 -> {5}
x3: 3 -> {5}
x4: 4 -> {5}
