-- do-notation
do
  x1 <- Dist.uniform [1, 2]
  x2 <- Dist.uniform [10, 20]
  x3 <- Dist.uniform [100, 200]
  x4 <- Dist.uniform [1000, 2000]
  x5 <- Dist.uniform [x1 + x2 + x3 + x4 + 10000, x1 + x2 + x3 + x4 + 20000]
  return (x1, x2, x3, x4, x5)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeApplicative
        (StmtTreeOne (x1_a1X5 <- Dist.uniform [1, 2], {Dist.uniform}))
        (StmtTreeOne (x2_a1X6 <- Dist.uniform [10, 20], {Dist.uniform}))
        (StmtTreeOne (x3_a1X7 <- Dist.uniform [100, 200], {Dist.uniform}))
        (StmtTreeOne (x4_a1X8 <- Dist.uniform [1000, 2000],
                      {Dist.uniform})))
     (StmtTreeOne (x5_a1X9 <- Dist.uniform
                                [x1_a1X5 + x2_a1X6 + x3_a1X7 + x4_a1X8 + 10000,
                                 x1_a1X5 + x2_a1X6 + x3_a1X7 + x4_a1X8 + 20000],
                   {x1_a1X5, x2_a1X6, x3_a1X7, x4_a1X8, +, Dist.uniform})))
  tree-cost = 2

-- Execution plan
(x1 | x2 | x3 | x4) ; x5
