-- Original program
CD.do
  root <- Dist.uniform [1, 2]
  a1 <- Dist.uniform [root + 10, root + 20]
  b1 <- Dist.uniform [root + 100, root + 200]
  join <- Dist.uniform [a1 + b1 + 1000, a1 + b1 + 2000]
  CD.return (root, a1, b1, join)

-- Internal representation with free variables by statement
ppsfa
  [(root_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}),
   (a1_a1Y5 <- Dist.uniform [root_a1Y4 + 10, root_a1Y4 + 20], {root_a1Y4, +, Dist.uniform}),
   (b1_a1Y6 <- Dist.uniform [root_a1Y4 + 100, root_a1Y4 + 200], {root_a1Y4, +, Dist.uniform}),
   (join_a1Y7 <- Dist.uniform [a1_a1Y5 + b1_a1Y6 + 1000, a1_a1Y5 + b1_a1Y6 + 2000], {a1_a1Y5, b1_a1Y6, +, Dist.uniform}),
   (CD.return (root_a1Y4, a1_a1Y5, b1_a1Y6, join_a1Y7), {root_a1Y4, a1_a1Y5, b1_a1Y6, join_a1Y7, CD.return})]

-- Precedence graph adjacency list
1 -> {2, 3}
2 -> {4}
3 -> {4}
4 -> {}

-- Precedence graph RAW dependencies grouped by binder
root: 1 -> {2, 3}
a1: 2 -> {4}
b1: 3 -> {4}
