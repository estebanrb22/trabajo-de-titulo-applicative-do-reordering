-- do-notation
do
  a1 <- Dist.uniform [1, 2]
  a2 <- Dist.uniform [a1 + 100, a1 + 200]
  a3 <- Dist.uniform [a2 + 10000, a2 + 20000]
  b1 <- Dist.uniform [10, 20]
  b2 <- Dist.uniform [b1 + 1000, b1 + 2000]
  b3 <- Dist.uniform [b2 + 100000, b2 + 200000]
  a4 <- Dist.uniform [a3 + 1000000, a3 + 2000000]
  b4 <- Dist.uniform [b3 + 10000000, b3 + 20000000]
  return (a1, a2, a3, a4, b1, b2, b3, b4)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeOne (a1_a1X5 <- Dist.uniform [1, 2], {Dist.uniform}))
     (StmtTreeBind
        (StmtTreeOne (a2_a1X6 <- Dist.uniform
                                   [a1_a1X5 + 100, a1_a1X5 + 200],
                      {a1_a1X5, +, Dist.uniform}))
        (StmtTreeBind
           (StmtTreeApplicative
              (StmtTreeOne (a3_a1X7 <- Dist.uniform
                                         [a2_a1X6 + 10000, a2_a1X6 + 20000],
                            {a2_a1X6, +, Dist.uniform}))
              (StmtTreeOne (b1_a1X8 <- Dist.uniform [10, 20], {Dist.uniform})))
           (StmtTreeBind
              (StmtTreeOne (b2_a1X9 <- Dist.uniform
                                         [b1_a1X8 + 1000, b1_a1X8 + 2000],
                            {b1_a1X8, +, Dist.uniform}))
              (StmtTreeBind
                 (StmtTreeApplicative
                    (StmtTreeOne (b3_a1Xa <- Dist.uniform
                                               [b2_a1X9 + 100000, b2_a1X9 + 200000],
                                  {b2_a1X9, +, Dist.uniform}))
                    (StmtTreeOne (a4_a1Xb <- Dist.uniform
                                               [a3_a1X7 + 1000000, a3_a1X7 + 2000000],
                                  {a3_a1X7, +, Dist.uniform})))
                 (StmtTreeOne (b4_a1Xc <- Dist.uniform
                                            [b3_a1Xa + 10000000, b3_a1Xa + 20000000],
                               {b3_a1Xa, +, Dist.uniform})))))))
  tree-cost = 6

-- Execution plan
a1 ; (a2 ; ((a3 | b1) ; (b2 ; ((b3 | a4) ; b4))))
