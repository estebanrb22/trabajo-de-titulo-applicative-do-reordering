-- Reordered do-notation
CD.do
  a1 <- Dist.uniform [1, 2]
  a2 <- Dist.uniform [a1 + 100, a1 + 200]
  b1 <- Dist.uniform [10, 20]
  b2 <- Dist.uniform [b1 + 1000, b1 + 2000]
  CD.return (a1, a2, b1, b2)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  2
  index-order =  [1, 3, 2, 4]
  statements  =  [a1_a1Y4 <- Dist.uniform [1, 2],
                  a2_a1Y6 <- Dist.uniform [a1_a1Y4 + 100, a1_a1Y4 + 200],
                  b1_a1Y5 <- Dist.uniform [10, 20],
                  b2_a1Y7 <- Dist.uniform [b1_a1Y5 + 1000, b1_a1Y5 + 2000]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeBind
          (StmtTreeOne (a1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}))
          (StmtTreeOne (a2_a1Y6 <- Dist.uniform
                                     [a1_a1Y4 + 100, a1_a1Y4 + 200],
                        {a1_a1Y4, +, Dist.uniform})))
       (StmtTreeBind
          (StmtTreeOne (b1_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}))
          (StmtTreeOne (b2_a1Y7 <- Dist.uniform
                                     [b1_a1Y5 + 1000, b1_a1Y5 + 2000],
                        {b1_a1Y5, +, Dist.uniform}))))
  tree-cost = 2

-- Execution plan
(a1 ; a2) | (b1 ; b2)
