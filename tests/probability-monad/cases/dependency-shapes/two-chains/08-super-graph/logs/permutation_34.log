-- Reordered do-notation
CD.do
  a1 <- Dist.uniform [1, 2]
  a2 <- Dist.uniform [a1 + 100, a1 + 200]
  a3 <- Dist.uniform [a1 + a2 + 10000, a1 + a2 + 20000]
  a4 <- Dist.uniform [a1 + a2 + a3 + 1000000, a1 + a2 + a3 + 2000000]
  b1 <- Dist.uniform [10, 20]
  b2 <- Dist.uniform [b1 + 1000, b1 + 2000]
  b3 <- Dist.uniform [b1 + b2 + 100000, b1 + b2 + 200000]
  b4 <- Dist.uniform [b1 + b2 + b3 + 10000000, b1 + b2 + b3 + 20000000]
  CD.return (a1, a2, a3, a4, b1, b2, b3, b4)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  34
  index-order =  [1, 3, 5, 7, 2, 4, 6, 8]
  statements  =  [a1_a1Y4 <- Dist.uniform [1, 2],
                  a2_a1Y6 <- Dist.uniform [a1_a1Y4 + 100, a1_a1Y4 + 200],
                  a3_a1Y8 <- Dist.uniform
                               [a1_a1Y4 + a2_a1Y6 + 10000, a1_a1Y4 + a2_a1Y6 + 20000],
                  a4_a1Ya <- Dist.uniform
                               [a1_a1Y4 + a2_a1Y6 + a3_a1Y8 + 1000000,
                                a1_a1Y4 + a2_a1Y6 + a3_a1Y8 + 2000000],
                  b1_a1Y5 <- Dist.uniform [10, 20],
                  b2_a1Y7 <- Dist.uniform [b1_a1Y5 + 1000, b1_a1Y5 + 2000],
                  b3_a1Y9 <- Dist.uniform
                               [b1_a1Y5 + b2_a1Y7 + 100000, b1_a1Y5 + b2_a1Y7 + 200000],
                  b4_a1Yb <- Dist.uniform
                               [b1_a1Y5 + b2_a1Y7 + b3_a1Y9 + 10000000,
                                b1_a1Y5 + b2_a1Y7 + b3_a1Y9 + 20000000]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeBind
          (StmtTreeOne (a1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}))
          (StmtTreeBind
             (StmtTreeOne (a2_a1Y6 <- Dist.uniform
                                        [a1_a1Y4 + 100, a1_a1Y4 + 200],
                           {a1_a1Y4, +, Dist.uniform}))
             (StmtTreeBind
                (StmtTreeOne (a3_a1Y8 <- Dist.uniform
                                           [a1_a1Y4 + a2_a1Y6 + 10000, a1_a1Y4 + a2_a1Y6 + 20000],
                              {a1_a1Y4, a2_a1Y6, +, Dist.uniform}))
                (StmtTreeOne (a4_a1Ya <- Dist.uniform
                                           [a1_a1Y4 + a2_a1Y6 + a3_a1Y8 + 1000000,
                                            a1_a1Y4 + a2_a1Y6 + a3_a1Y8 + 2000000],
                              {a1_a1Y4, a2_a1Y6, a3_a1Y8, +, Dist.uniform})))))
       (StmtTreeBind
          (StmtTreeOne (b1_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}))
          (StmtTreeBind
             (StmtTreeOne (b2_a1Y7 <- Dist.uniform
                                        [b1_a1Y5 + 1000, b1_a1Y5 + 2000],
                           {b1_a1Y5, +, Dist.uniform}))
             (StmtTreeBind
                (StmtTreeOne (b3_a1Y9 <- Dist.uniform
                                           [b1_a1Y5 + b2_a1Y7 + 100000, b1_a1Y5 + b2_a1Y7 + 200000],
                              {b1_a1Y5, b2_a1Y7, +, Dist.uniform}))
                (StmtTreeOne (b4_a1Yb <- Dist.uniform
                                           [b1_a1Y5 + b2_a1Y7 + b3_a1Y9 + 10000000,
                                            b1_a1Y5 + b2_a1Y7 + b3_a1Y9 + 20000000],
                              {b1_a1Y5, b2_a1Y7, b3_a1Y9, +, Dist.uniform}))))))
  tree-cost = 4

-- Execution plan
(a1 ; (a2 ; (a3 ; a4))) | (b1 ; (b2 ; (b3 ; b4)))
