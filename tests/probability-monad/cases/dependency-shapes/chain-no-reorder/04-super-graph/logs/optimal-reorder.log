-- Reordered do-notation
CD.do
  x1 <- Dist.uniform [1, 2]
  x2 <- Dist.uniform [x1 + 10, x1 + 20]
  x3 <- Dist.uniform [x1 + x2 + 100, x1 + x2 + 200]
  x4 <- Dist.uniform [x1 + x2 + x3 + 1000, x1 + x2 + x3 + 2000]
  CD.return (x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  0
  index-order =  [1, 2, 3, 4]
  statements  =  [x1_a1Y4 <- Dist.uniform [1, 2],
                  x2_a1Y5 <- Dist.uniform [x1_a1Y4 + 10, x1_a1Y4 + 20],
                  x3_a1Y6 <- Dist.uniform
                               [x1_a1Y4 + x2_a1Y5 + 100, x1_a1Y4 + x2_a1Y5 + 200],
                  x4_a1Y7 <- Dist.uniform
                               [x1_a1Y4 + x2_a1Y5 + x3_a1Y6 + 1000,
                                x1_a1Y4 + x2_a1Y5 + x3_a1Y6 + 2000]]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeOne (x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}))
       (StmtTreeBind
          (StmtTreeOne (x2_a1Y5 <- Dist.uniform [x1_a1Y4 + 10, x1_a1Y4 + 20],
                        {x1_a1Y4, +, Dist.uniform}))
          (StmtTreeBind
             (StmtTreeOne (x3_a1Y6 <- Dist.uniform
                                        [x1_a1Y4 + x2_a1Y5 + 100, x1_a1Y4 + x2_a1Y5 + 200],
                           {x1_a1Y4, x2_a1Y5, +, Dist.uniform}))
             (StmtTreeOne (x4_a1Y7 <- Dist.uniform
                                        [x1_a1Y4 + x2_a1Y5 + x3_a1Y6 + 1000,
                                         x1_a1Y4 + x2_a1Y5 + x3_a1Y6 + 2000],
                           {x1_a1Y4, x2_a1Y5, x3_a1Y6, +, Dist.uniform})))))
  tree-cost = 4

-- Execution plan
x1 ; (x2 ; (x3 ; x4))
