-- Reordered do-notation
CD.do
  x3 <- Dist.uniform [100, 200]
  x2 <- Dist.uniform [10, 20]
  x1 <- Dist.uniform [1, 2]
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  5
  index-order =  [3, 2, 1]
  statements  =  [x3_a1Y6 <- Dist.uniform [100, 200],
                  x2_a1Y5 <- Dist.uniform [10, 20], x1_a1Y4 <- Dist.uniform [1, 2]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform}))
       (StmtTreeOne (x2_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}))
       (StmtTreeOne (x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform})))
  tree-cost = 1

-- Execution plan
x3 | x2 | x1
