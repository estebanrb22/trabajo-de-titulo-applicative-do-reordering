-- Original program
CD.do
  x1 <- Dist.uniform [1, 2]
  x2 <- Dist.uniform [10, 20]
  x3 <- Dist.uniform [100, 200]
  x4 <- Dist.uniform [1000, 2000]
  CD.return (x1, x2, x3, x4)

-- Internal representation with free variables by statement
ppsfa
  [(x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}),
   (x2_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}),
   (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform}),
   (x4_a1Y7 <- Dist.uniform [1000, 2000], {Dist.uniform}),
   (CD.return (x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7), {x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7, CD.return})]

