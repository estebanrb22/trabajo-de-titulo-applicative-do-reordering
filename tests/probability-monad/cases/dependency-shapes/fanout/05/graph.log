-- Original program
CD.do
  x1 <- Dist.uniform [1, 2]
  x2 <- Dist.uniform [x1 + 10, x1 + 20]
  x3 <- Dist.uniform [x1 + 100, x1 + 200]
  x4 <- Dist.uniform [x1 + 1000, x1 + 2000]
  x5 <- Dist.uniform [x1 + 10000, x1 + 20000]
  CD.return (x1, x2, x3, x4, x5)

-- Internal representation with free variables by statement
ppsfa
  [(x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}),
   (x2_a1Y5 <- Dist.uniform [x1_a1Y4 + 10, x1_a1Y4 + 20], {x1_a1Y4, +, Dist.uniform}),
   (x3_a1Y6 <- Dist.uniform [x1_a1Y4 + 100, x1_a1Y4 + 200], {x1_a1Y4, +, Dist.uniform}),
   (x4_a1Y7 <- Dist.uniform [x1_a1Y4 + 1000, x1_a1Y4 + 2000], {x1_a1Y4, +, Dist.uniform}),
   (x5_a1Y8 <- Dist.uniform [x1_a1Y4 + 10000, x1_a1Y4 + 20000], {x1_a1Y4, +, Dist.uniform}),
   (CD.return (x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7, x5_a1Y8), {x1_a1Y4, x2_a1Y5, x3_a1Y6, x4_a1Y7, x5_a1Y8, CD.return})]

