-- Original program
CD.do
  x1 <- Dist.uniform [1, 2]
  (Dist.Cons [] :: Dist.T Rational ())
  x2 <- Dist.uniform [10, 20]
  CD.return (x1, x2)

-- Internal representation with free variables by statement
ppsfa
  [(x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}),
   ((Dist.Cons [] :: Dist.T Rational ()), {Rational, [], Dist.T, Dist.Cons}),
   (x2_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}),
   (CD.return (x1_a1Y4, x2_a1Y5), {x1_a1Y4, x2_a1Y5, CD.return})]

