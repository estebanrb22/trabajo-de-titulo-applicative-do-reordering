-- Reordered do-notation
CD.do
  x1 <- Dist.uniform [1, 2]
  x3 <- Dist.uniform [100, 200]
  x2 <- Dist.filter even (Dist.uniform [x1, x1 + 1, x1 + 2])
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [1, 3, 2]
  statements  =  [x1_a1Y4 <- Dist.uniform [1, 2],
                  x3_a1Y6 <- Dist.uniform [100, 200],
                  x2_a1Y5 <- Dist.filter
                               even (Dist.uniform [x1_a1Y4, x1_a1Y4 + 1, x1_a1Y4 + 2])]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}))
          (StmtTreeOne (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform})))
       (StmtTreeOne (x2_a1Y5 <- Dist.filter
                                  even (Dist.uniform [x1_a1Y4, x1_a1Y4 + 1, x1_a1Y4 + 2]),
                     {x1_a1Y4, even, +, Dist.filter, Dist.uniform})))
  tree-cost = 2

-- Execution plan
(x1 | x3) ; x2
