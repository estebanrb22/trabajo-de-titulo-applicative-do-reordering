-- do-notation
do
  x1 <- Dist.uniform [1, 2]
  x2 <- Dist.uniform [x1 + 10, x1 + 20]
  x3 <- Dist.uniform [100, 200]
  x4 <- Dist.uniform [x3 + 1000, x3 + 2000]
  x5 <- Dist.uniform [x4 + 10000, x4 + 20000]
  x6 <- Dist.uniform [x2 + 100000, x2 + 200000]
  return (x1, x2, x3, x4, x5, x6)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeOne (x1_a1X5 <- Dist.uniform [1, 2], {Dist.uniform}))
     (StmtTreeBind
        (StmtTreeApplicative
           (StmtTreeOne (x2_a1X6 <- Dist.uniform [x1_a1X5 + 10, x1_a1X5 + 20],
                         {x1_a1X5, +, Dist.uniform}))
           (StmtTreeOne (x3_a1X7 <- Dist.uniform [100, 200], {Dist.uniform})))
        (StmtTreeApplicative
           (StmtTreeBind
              (StmtTreeOne (x4_a1X8 <- Dist.uniform
                                         [x3_a1X7 + 1000, x3_a1X7 + 2000],
                            {x3_a1X7, +, Dist.uniform}))
              (StmtTreeOne (x5_a1X9 <- Dist.uniform
                                         [x4_a1X8 + 10000, x4_a1X8 + 20000],
                            {x4_a1X8, +, Dist.uniform})))
           (StmtTreeOne (x6_a1Xa <- Dist.uniform
                                      [x2_a1X6 + 100000, x2_a1X6 + 200000],
                         {x2_a1X6, +, Dist.uniform})))))
  tree-cost = 4

-- Execution plan
x1 ; ((x2 | x3) ; ((x4 ; x5) | x6))
