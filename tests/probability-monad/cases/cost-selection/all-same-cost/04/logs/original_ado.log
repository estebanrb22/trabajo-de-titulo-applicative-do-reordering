-- do-notation
do
  x1 <- Dist.uniform [1, 2]
  x2 <- Dist.uniform [x1 + 10, x1 + 20]
  x3 <- Dist.uniform [x1 + 100, x1 + 200]
  x4 <- Dist.uniform [x1 + 1000, x1 + 2000]
  return (x1, x2, x3, x4)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeBind
     (StmtTreeOne (x1_a1X5 <- Dist.uniform [1, 2], {Dist.uniform}))
     (StmtTreeApplicative
        (StmtTreeOne (x2_a1X6 <- Dist.uniform [x1_a1X5 + 10, x1_a1X5 + 20],
                      {x1_a1X5, +, Dist.uniform}))
        (StmtTreeOne (x3_a1X7 <- Dist.uniform
                                   [x1_a1X5 + 100, x1_a1X5 + 200],
                      {x1_a1X5, +, Dist.uniform}))
        (StmtTreeOne (x4_a1X8 <- Dist.uniform
                                   [x1_a1X5 + 1000, x1_a1X5 + 2000],
                      {x1_a1X5, +, Dist.uniform}))))
  tree-cost = 2

-- Execution plan
x1 ; (x2 | x3 | x4)
