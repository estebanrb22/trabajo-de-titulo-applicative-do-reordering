-- Original program
CD.do
  a1 <- Dist.uniform [1, 2]
  b1 <- Dist.uniform [10, 20]
  a2 <- Dist.uniform [a1 + 100, a1 + 200]
  b2 <- Dist.uniform [b1 + 1000, b1 + 2000]
  CD.return (a1, a2, b1, b2)

-- Internal representation with free variables by statement
ppsfa
  [(a1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}),
   (b1_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}),
   (a2_a1Y6 <- Dist.uniform [a1_a1Y4 + 100, a1_a1Y4 + 200], {a1_a1Y4, +, Dist.uniform}),
   (b2_a1Y7 <- Dist.uniform [b1_a1Y5 + 1000, b1_a1Y5 + 2000], {b1_a1Y5, +, Dist.uniform}),
   (CD.return (a1_a1Y4, a2_a1Y6, b1_a1Y5, b2_a1Y7), {a1_a1Y4, b1_a1Y5, a2_a1Y6, b2_a1Y7, CD.return})]

-- Precedence graph adjacency list
1 -> {3}
2 -> {4}
3 -> {}
4 -> {}

-- Precedence graph RAW dependencies grouped by binder
a1: 1 -> {3}
b1: 2 -> {4}
