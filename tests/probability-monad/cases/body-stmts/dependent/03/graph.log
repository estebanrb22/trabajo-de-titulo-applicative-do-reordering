-- Original program
CD.do
  x1 <- Dist.uniform [1, 2]
  Dist.certainly (x1 + 10)
  x2 <- Dist.uniform [100, 200]
  CD.return (x1, x2)

-- Internal representation with free variables by statement
ppsfa
  [(x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}),
   (Dist.certainly (x1_a1Y4 + 10), {x1_a1Y4, +, Dist.certainly}),
   (x2_a1Y5 <- Dist.uniform [100, 200], {Dist.uniform}),
   (CD.return (x1_a1Y4, x2_a1Y5), {x1_a1Y4, x2_a1Y5, CD.return})]

-- Precedence graph adjacency list
1 -> {2}
2 -> {}
3 -> {}

-- Precedence graph RAW dependencies grouped by binder
x1: 1 -> {2}
