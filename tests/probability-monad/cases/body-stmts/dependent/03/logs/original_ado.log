-- do-notation
do
  x1 <- Dist.uniform [1, 2]
  Dist.certainly (x1 + 10)
  x2 <- Dist.uniform [100, 200]
  return (x1, x2)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeBind
        (StmtTreeOne (x1_a1X5 <- Dist.uniform [1, 2], {Dist.uniform}))
        (StmtTreeOne (Dist.certainly (x1_a1X5 + 10),
                      {x1_a1X5, +, Dist.certainly})))
     (StmtTreeOne (x2_a1X6 <- Dist.uniform [100, 200], {Dist.uniform})))
  tree-cost = 2

-- Execution plan
(x1 ; stmt2) | x2
