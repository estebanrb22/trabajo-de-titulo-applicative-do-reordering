-- Reordered do-notation
CD.do
  x1 <- Dist.uniform [1, 2]
  x2 <- Dist.uniform [100, 200]
  Dist.certainly (x1 + 10)
  CD.return (x1, x2)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [1, 3, 2]
  statements  =  [x1_a1Y4 <- Dist.uniform [1, 2],
                  x2_a1Y5 <- Dist.uniform [100, 200], Dist.certainly (x1_a1Y4 + 10)]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}))
          (StmtTreeOne (x2_a1Y5 <- Dist.uniform [100, 200], {Dist.uniform})))
       (StmtTreeOne (Dist.certainly (x1_a1Y4 + 10),
                     {x1_a1Y4, +, Dist.certainly})))
  tree-cost = 2

-- Execution plan
(x1 | x2) ; stmt2
