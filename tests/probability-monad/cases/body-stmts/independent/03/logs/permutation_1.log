-- Reordered do-notation
CD.do
  x1 <- Dist.uniform [1, 2]
  x2 <- Dist.uniform [10, 20]
  Dist.certainly ()
  CD.return (x1, x2)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [1, 3, 2]
  statements  =  [x1_a1Y4 <- Dist.uniform [1, 2],
                  x2_a1Y5 <- Dist.uniform [10, 20], Dist.certainly ()]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x1_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}))
       (StmtTreeOne (x2_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}))
       (StmtTreeOne (Dist.certainly (), {(), Dist.certainly})))
  tree-cost = 1

-- Execution plan
x1 | x2 | stmt2
