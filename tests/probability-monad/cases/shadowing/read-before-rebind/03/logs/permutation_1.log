-- Reordered do-notation
CD.do
  x <- Dist.uniform [1, 2]
  x <- Dist.uniform [100, 200]
  y <- Dist.uniform [x + 10, x + 20]
  CD.return (y, x)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [1, 3, 2]
  statements  =  [x_a1Y4 <- Dist.uniform [1, 2],
                  x_a1Y6 <- Dist.uniform [100, 200],
                  y_a1Y5 <- Dist.uniform [x_a1Y4 + 10, x_a1Y4 + 20]]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}))
          (StmtTreeOne (x_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform})))
       (StmtTreeOne (y_a1Y5 <- Dist.uniform [x_a1Y4 + 10, x_a1Y4 + 20],
                     {x_a1Y4, +, Dist.uniform})))
  tree-cost = 2

-- Execution plan
(x | x) ; y
