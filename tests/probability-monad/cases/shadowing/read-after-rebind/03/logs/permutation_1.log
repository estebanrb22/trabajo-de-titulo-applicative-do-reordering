-- Reordered do-notation
CD.do
  x <- Dist.uniform [10, 20]
  x <- Dist.uniform [1, 2]
  y <- Dist.uniform [x + 100, x + 200]
  CD.return (x, y)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [2, 1, 3]
  statements  =  [x_a1Y5 <- Dist.uniform [10, 20],
                  x_a1Y4 <- Dist.uniform [1, 2],
                  y_a1Y6 <- Dist.uniform [x_a1Y5 + 100, x_a1Y5 + 200]]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}))
          (StmtTreeOne (x_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform})))
       (StmtTreeOne (y_a1Y6 <- Dist.uniform [x_a1Y5 + 100, x_a1Y5 + 200],
                     {x_a1Y5, +, Dist.uniform})))
  tree-cost = 2

-- Execution plan
(x | x) ; y
