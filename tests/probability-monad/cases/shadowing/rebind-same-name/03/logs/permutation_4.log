-- Reordered do-notation
CD.do
  y <- Dist.uniform [100, 200]
  x <- Dist.uniform [1, 2]
  x <- Dist.uniform [10, 20]
  CD.return (x, y)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  4
  index-order =  [3, 1, 2]
  statements  =  [y_a1Y6 <- Dist.uniform [100, 200],
                  x_a1Y4 <- Dist.uniform [1, 2], x_a1Y5 <- Dist.uniform [10, 20]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (y_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform}))
       (StmtTreeOne (x_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}))
       (StmtTreeOne (x_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform})))
  tree-cost = 1

-- Execution plan
y | x | x
