-- Reordered do-notation
CD.do
  x <- Dist.uniform [10, 20]
  x <- Dist.uniform [1, 2]
  x <- Dist.uniform [100, 200]
  CD.return x

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  2
  index-order =  [2, 1, 3]
  statements  =  [x_a1Y5 <- Dist.uniform [10, 20],
                  x_a1Y4 <- Dist.uniform [1, 2], x_a1Y6 <- Dist.uniform [100, 200]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}))
       (StmtTreeOne (x_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}))
       (StmtTreeOne (x_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform})))
  tree-cost = 1

-- Execution plan
x | x | x
