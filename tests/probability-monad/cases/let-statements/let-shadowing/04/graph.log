-- Original program
CD.do
  x <- Dist.uniform [1, 2]
  oldX <- Dist.certainly x
  let x = 100
  y <- Dist.uniform [x + oldX, x + oldX + 1]
  CD.return (oldX, x, y)

-- Internal representation with free variables by statement
ppsfa
  [(x_a1Y4 <- Dist.uniform [1, 2], {Dist.uniform}),
   (oldX_a1Y5 <- Dist.certainly x_a1Y4, {x_a1Y4, Dist.certainly}),
   (let x_a1Y6 = 100, {}),
   (y_a1Y7 <- Dist.uniform [x_a1Y6 + oldX_a1Y5, x_a1Y6 + oldX_a1Y5 + 1], {oldX_a1Y5, x_a1Y6, +, Dist.uniform}),
   (CD.return (oldX_a1Y5, x_a1Y6, y_a1Y7), {oldX_a1Y5, x_a1Y6, y_a1Y7, CD.return})]

-- Precedence graph adjacency list
1 -> {2}
2 -> {4}
3 -> {4}
4 -> {}

-- Precedence graph RAW dependencies grouped by binder
x@1: 1 -> {2}
oldX: 2 -> {4}
x@3: 3 -> {4}
