-- do-notation
do
  x1 <- Dist.uniform [10, 20]
  let x2 = x1 + 1
  x3 <- Dist.uniform [100, 200]
  return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeBind
        (StmtTreeOne (x1_a1X5 <- Dist.uniform [10, 20], {Dist.uniform}))
        (StmtTreeOne (let x2_a1X6 = x1_a1X5 + 1, {x1_a1X5, +})))
     (StmtTreeOne (x3_a1X7 <- Dist.uniform [100, 200], {Dist.uniform})))
  tree-cost = 2

-- Execution plan
(x1 ; x2) | x3
