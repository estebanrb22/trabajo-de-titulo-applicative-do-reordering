-- Reordered do-notation
CD.do
  x1 <- Dist.uniform [10, 20]
  x3 <- Dist.uniform [100, 200]
  let x2 = x1 + 1
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  1
  index-order =  [1, 3, 2]
  statements  =  [x1_a1Y4 <- Dist.uniform [10, 20],
                  x3_a1Y6 <- Dist.uniform [100, 200], let x2_a1Y5 = x1_a1Y4 + 1]
  rearrangeForADo-resulting tree =
    (StmtTreeBind
       (StmtTreeApplicative
          (StmtTreeOne (x1_a1Y4 <- Dist.uniform [10, 20], {Dist.uniform}))
          (StmtTreeOne (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform})))
       (StmtTreeOne (let x2_a1Y5 = x1_a1Y4 + 1, {x1_a1Y4, +})))
  tree-cost = 2

-- Execution plan
(x1 | x3) ; x2
