-- do-notation
do
  let x1 = 10
  x2 <- Dist.uniform [x1 + 1, x1 + 2]
  x3 <- Dist.uniform [100, 200]
  return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  (StmtTreeApplicative
     (StmtTreeBind
        (StmtTreeOne (let x1_a1X5 = 10, {}))
        (StmtTreeOne (x2_a1X6 <- Dist.uniform [x1_a1X5 + 1, x1_a1X5 + 2],
                      {x1_a1X5, +, Dist.uniform})))
     (StmtTreeOne (x3_a1X7 <- Dist.uniform [100, 200], {Dist.uniform})))
  tree-cost = 2

-- Execution plan
(x1 ; x2) | x3
