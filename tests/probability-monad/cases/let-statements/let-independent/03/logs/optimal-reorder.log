-- Reordered do-notation
CD.do
  x2 <- Dist.uniform [10, 20]
  x3 <- Dist.uniform [100, 200]
  let x1 = 1
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo final tree:
  candidate   =  3
  index-order =  [2, 3, 1]
  statements  =  [x2_a1Y5 <- Dist.uniform [10, 20],
                  x3_a1Y6 <- Dist.uniform [100, 200], let x1_a1Y4 = 1]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x2_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}))
       (StmtTreeOne (x3_a1Y6 <- Dist.uniform [100, 200], {Dist.uniform}))
       (StmtTreeOne (let x1_a1Y4 = 1, {})))
  tree-cost = 1

-- Execution plan
x2 | x3 | x1
