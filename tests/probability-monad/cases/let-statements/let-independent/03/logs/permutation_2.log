-- Reordered do-notation
CD.do
  x2 <- Dist.uniform [10, 20]
  let x1 = 1
  x3 <- Dist.uniform [100, 200]
  CD.return (x1, x2, x3)

-- Renamer trace
rearrangeForADo candidate selection tree (fado-reorder-candidate-n) =
  candidate   =  2
  index-order =  [2, 1, 3]
  statements  =  [x2_a1Y5 <- Dist.uniform [10, 20], let x1_a1Y4 = 1,
                  x3_a1Y6 <- Dist.uniform [100, 200]]
  rearrangeForADo-resulting tree =
    (StmtTreeApplicative
       (StmtTreeOne (x2_a1Y5 <- Dist.uniform [10, 20], {Dist.uniform}))
       (StmtTreeBind
          (StmtTreeOne (let x1_a1Y4 = 1, {}))
          (StmtTreeOne (x3_a1Y6 <- Dist.uniform [100, 200],
                        {Dist.uniform}))))
  tree-cost = 2

-- Execution plan
x2 | (x1 ; x3)
